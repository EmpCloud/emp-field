                    <View
                        android:id="@+id/view_firstName"
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_marginLeft="@dimen/text_fifteen"
                        android:layout_marginTop="10dp"
                        android:layout_marginRight="@dimen/text_fifteen"
                        android:background="@color/view_horizontal_line_color"

                        />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/margin_twenty"
                                android:text="@string/address"
                                android:textColor="@color/user_form_text_color"
                                android:textSize="@dimen/text_fifteen"
                                android:textStyle="bold"
                                android:theme="@style/monstreat_semibold" />

                            <TextView
                                android:id="@+id/address"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/margin_ten"
                                android:text="107, street 6A, Bidadi, \nBengaluru, India"
                                android:textColor="#4D4C4C"
                                android:textSize="@dimen/text_twelve"
                                android:textStyle="bold"
                                android:theme="@style/FontMedium" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/editbtn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_twenty"
                            android:background="@drawable/edit_btn_bg"
                            android:clickable="true"
                            android:foreground="@drawable/ripple"
                            android:orientation="horizontal"
                            android:paddingStart="@dimen/margin_twenty"
                            android:paddingTop="@dimen/margin_five"
                            android:paddingEnd="@dimen/margin_twenty"
                            android:paddingBottom="@dimen/margin_five"
                            android:visibility="visible"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintHorizontal_bias="0.0"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/linearLayout">

                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:layout_marginEnd="@dimen/margin_five"
                                android:src="@drawable/edit_icon"
                                app:tint="@color/white" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:fontFamily="@font/montserrat_medium"
                                android:gravity="center"
                                android:text="@string/edit"
                                android:textColor="@color/white"
                                android:textSize="10sp" />
                        </LinearLayout>


                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/savebtn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="@dimen/margin_twenty"
                        android:layout_marginBottom="100dp"
                        android:background="@drawable/edit_btn_bg"
                        android:clickable="true"
                        android:foreground="@drawable/ripple"
                        android:orientation="vertical"
                        android:paddingStart="@dimen/margin_twenty"
                        android:paddingTop="@dimen/padding_ten"
                        android:paddingEnd="@dimen/margin_twenty"
                        android:paddingBottom="@dimen/padding_ten"
                        android:visibility="visible"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_bias="0.0"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/linearLayout">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:fontFamily="@font/montserrat_medium"
                            android:gravity="center"
                            android:text="@string/save"
                            android:textColor="@color/white"
                            android:textSize="10sp" />
                    </LinearLayout>


                </LinearLayout>

            </ScrollView>


