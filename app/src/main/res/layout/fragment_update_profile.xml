<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.fragment.update_profile.UpdateProfileFragment">


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/linearLayout2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_twenty"
        android:layout_marginStart="@dimen/margin_twenty"
        android:layout_marginEnd="@dimen/margin_fifteen"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">


        <androidx.cardview.widget.CardView
            android:id="@+id/backbtn"
            android:clickable="true"
            android:layout_width="30dp"
            android:layout_height="30dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="15dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:padding="3dp"
                android:layout_gravity="center"
                android:src="@drawable/baseline_arrow_back_24" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/profile"
            android:textColor="@color/white"
            android:textSize="@dimen/text_twenty"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>


    <RelativeLayout
        android:id="@+id/relativeLayout"
        android:layout_width="115dp"
        android:layout_height="115dp"
        android:layout_marginTop="@dimen/margin_twenty"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout2">

        <androidx.cardview.widget.CardView
            android:layout_width="100dp"
            android:layout_height="100dp"
            app:cardCornerRadius="50dp"
            android:layout_centerInParent="true"
            android:background="@drawable/user_profile_background"
            android:gravity="center">

            <ImageView
                android:id="@+id/userPic"
                android:visibility="gone"
                android:layout_gravity="center"
                android:scaleType="centerCrop"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/defalut_user_ico" />


            <ImageView
                android:id="@+id/userPicdisbale"
                android:visibility="visible"
                android:layout_gravity="center"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:src="@drawable/userprofile_icon" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_gravity="center"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
<!--            <ImageView-->
<!--                android:id="@+id/loading"-->
<!--                android:visibility="gone"-->
<!--                android:layout_gravity="center"-->
<!--                android:layout_width="wrap_content"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:src="@drawable/loading"-->
<!--                app:tint="@color/buttonbgcolor" />-->
        </androidx.cardview.widget.CardView>


        <LinearLayout
            android:id="@+id/cameraProfile"
            android:translationZ="2dp"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentBottom="true"
            android:foreground="@drawable/ripple_fab"
            android:clickable="true"
            android:gravity="center"
            android:background="@drawable/user_image_upload_back"
            android:layout_alignParentEnd="true">
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@drawable/icon_camera" />
        </LinearLayout>

    </RelativeLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        app:cardBackgroundColor="@color/white"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/margin_fifteen"
        android:layout_marginTop="@dimen/margin_twenty"
        android:layout_marginEnd="@dimen/margin_fifteen"
        android:layout_marginBottom="@dimen/margin_thirty"
        app:cardCornerRadius="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/relativeLayout">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_twenty"
                    android:layout_marginTop="@dimen/margin_twenty"
                    android:layout_marginEnd="@dimen/margin_twenty"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/full_name"
                        android:textColor="@color/user_form_text_color"
                        android:textSize="@dimen/text_fifteen"
                        android:textStyle="bold"
                        android:theme="@style/FontMedium" />

                    <EditText
                        android:id="@+id/name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_ten"
                        android:background="@drawable/user_screen_edittext_bg"
                        android:hint="@string/enter_your_name"
                        android:inputType="text"
                        android:paddingStart="@dimen/padding_ten"
                        android:paddingTop="@dimen/padding_ten"
                        android:paddingBottom="@dimen/padding_ten"
                        android:textColor="#5F5F5F"
                        android:textSize="12sp"
                        android:theme="@style/FontMedium" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_twenty"
                        android:text="@string/email_id_ma"
                        android:textColor="@color/user_form_text_color"
                        android:textSize="@dimen/text_fifteen"
                        android:textStyle="bold"
                        android:theme="@style/FontMedium" />

                    <EditText
                        android:id="@+id/email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_ten"
                        android:background="@drawable/user_screen_edittext_bg"
                        android:hint="@string/enter_email_id"
                        android:inputType="none"
                        android:paddingStart="@dimen/padding_ten"
                        android:paddingTop="@dimen/padding_ten"
                        android:paddingBottom="@dimen/padding_ten"
                        android:textColor="#5F5F5F"
                        android:textSize="12sp"
                        android:theme="@style/FontMedium" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_twenty"
                        android:text="@string/mobile_no"
                        android:textColor="@color/user_form_text_color"
                        android:textSize="@dimen/text_fifteen"
                        android:textStyle="bold"
                        android:theme="@style/FontMedium" />

                    <EditText
                        android:id="@+id/mobileNo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_ten"
                        android:background="@drawable/user_screen_edittext_bg"
                        android:hint="@string/enter_mobile_no"
                        android:inputType="text"
                        android:paddingStart="@dimen/padding_ten"
                        android:paddingTop="@dimen/padding_ten"
                        android:paddingBottom="@dimen/padding_ten"
                        android:textColor="#5F5F5F"
                        android:textSize="12sp"
                        android:theme="@style/FontMedium" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_twenty"
                        android:text="@string/age"
                        android:textColor="@color/user_form_text_color"
                        android:textSize="@dimen/text_fifteen"
                        android:textStyle="bold"
                        android:theme="@style/FontMedium" />

                    <EditText
                        android:id="@+id/age"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_ten"
                        android:background="@drawable/user_screen_edittext_bg"
                        android:hint="@string/enter_your_age"
                        android:inputType="number"
                        android:maxLength="2"
                        android:paddingStart="@dimen/padding_ten"
                        android:paddingTop="@dimen/padding_ten"
                        android:paddingBottom="@dimen/padding_ten"
                        android:textColor="#5F5F5F"
                        android:textSize="12sp"
                        android:theme="@style/FontMedium" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_twenty"
                        android:text="@string/gender"
                        android:textColor="@color/user_form_text_color"
                        android:textSize="@dimen/text_fifteen"
                        android:textStyle="bold"
                        android:theme="@style/FontMedium" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_ten"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/malesection"
                            android:clickable="true"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/margin_thirty"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/male_unselect"
                                android:visibility="visible"
                                android:layout_width="wrap_content"
                                android:src="@drawable/radio_btn_custom_aman"
                                android:adjustViewBounds="true"
                                android:layout_gravity="center"
                                android:layout_height="wrap_content"/>

                            <ImageView
                                android:id="@+id/male_select"
                                android:visibility="gone"
                                android:layout_width="wrap_content"
                                android:src="@drawable/checked_radio_btn_aman"
                                android:adjustViewBounds="true"
                                android:layout_gravity="center"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/margin_ten"
                                android:layout_gravity="center"
                                android:gravity="center"
                                android:text="@string/male"
                                android:theme="@style/UbuntuMedium"
                                android:textColor="@color/radio_button_text_color"
                                android:textSize="@dimen/text_fourteen" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/femalesction"
                            android:clickable="true"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/margin_thirty"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/female_unselect"
                                android:visibility="visible"
                                android:layout_width="wrap_content"
                                android:src="@drawable/radio_btn_custom_aman"
                                android:adjustViewBounds="true"
                                android:layout_gravity="center"
                                android:layout_height="wrap_content"/>

                            <ImageView
                                android:id="@+id/female_select"
                                android:visibility="gone"
                                android:layout_width="wrap_content"
                                android:src="@drawable/checked_radio_btn_aman"
                                android:adjustViewBounds="true"
                                android:layout_gravity="center"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/margin_ten"
                                android:layout_gravity="center"
                                android:gravity="center"
                                android:text="@string/female"
                                android:theme="@style/UbuntuMedium"
                                android:textColor="@color/radio_button_text_color"
                                android:textSize="@dimen/text_fourteen" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/othersection"
                            android:clickable="true"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/margin_thirty"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/others_unselect"
                                android:visibility="visible"
                                android:layout_width="wrap_content"
                                android:src="@drawable/radio_btn_custom_aman"
                                android:adjustViewBounds="true"
                                android:layout_gravity="center"
                                android:layout_height="wrap_content"/>

                            <ImageView
                                android:id="@+id/other_select"
                                android:visibility="gone"
                                android:layout_width="wrap_content"
                                android:src="@drawable/checked_radio_btn_aman"
                                android:adjustViewBounds="true"
                                android:layout_gravity="center"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/margin_ten"
                                android:layout_gravity="center"
                                android:gravity="center"
                                android:text="@string/other"
                                android:theme="@style/UbuntuMedium"
                                android:textColor="@color/radio_button_text_color"
                                android:textSize="@dimen/text_fourteen" />
                        </LinearLayout>
                    </LinearLayout>

<!--                    <RadioGroup-->
<!--                        android:id="@+id/radiogrp"-->
<!--                        android:layout_width="match_parent"-->
