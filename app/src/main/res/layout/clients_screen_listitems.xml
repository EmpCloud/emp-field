<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_marginBottom="@dimen/margin_ten"
    android:layout_marginStart="@dimen/margin_fifteen"
    android:layout_marginEnd="@dimen/margin_fifteen"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">


    <LinearLayout
        android:id="@+id/firstRecycler"
        android:foreground="@drawable/ripple_new_aman"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="visible"
        android:layout_gravity="center"
        android:background="@drawable/edit_text_back"
        android:orientation="horizontal"
        android:paddingStart="@dimen/padding_ten"
        android:paddingTop="@dimen/margin_twenty"
        android:paddingEnd="@dimen/padding_ten"
        android:paddingBottom="@dimen/margin_twenty"
        app:layout_constraintTop_toTopOf="parent"
        tools:layout_editor_absoluteX="5dp">


        <ImageView
            android:id="@+id/profilePicdisable"
            android:visibility="visible"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:adjustViewBounds="true"
            android:background="@drawable/gradient_circular_back_shap"
            android:padding="@dimen/padding_ten"
            android:src="@drawable/icon_user_profile"
            app:tint="@color/white" />

        <androidx.cardview.widget.CardView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:visibility="gone"
            android:id="@+id/picard"
            app:cardCornerRadius="20dp">

            <ImageView
                android:id="@+id/profilePic"
                android:visibility="visible"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:scaleType="centerCrop" />

        </androidx.cardview.widget.CardView>



        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/margin_five"
            android:layout_weight="1"
            android:layout_gravity="center"
            android:layout_marginStart="@dimen/margin_five"
            android:orientation="vertical">

            <TextView
                android:id="@+id/clientName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="start"
                android:text="Aman Singh"
                android:textColor="@color/grey_text_color"
                android:textSize="@dimen/text_fifteen" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="@dimen/margin_five"
                android:orientation="horizontal">
                <ImageView
                    android:id="@+id/location"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="@dimen/margin_five"
                    android:layout_gravity="center"
                    android:background="@drawable/home_page_holidays_shape_back"
                    android:padding="@dimen/margin_five"
                    android:src="@drawable/baseline_location_on_24"
                    android:visibility="visible" />
                <TextView
                    android:id="@+id/address"
                    android:maxLines="1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="start"
                    android:text="devansh@gmail.com"
                    android:textColor="@color/grey_text_color"
                    android:textSize="@dimen/text_twelve"
                    android:theme="@style/FontMedium" />

            </LinearLayout>
        </LinearLayout>
<!--        <androidx.constraintlayout.widget.ConstraintLayout-->
<!--            android:layout_width="match_parent"-->
<!--            android:layout_height="match_parent">-->

        <LinearLayout
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/margin_five"
            android:layout_gravity="center"
            android:gravity="end">
            <ImageView
                android:id="@+id/dropdown_menu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@drawable/dropdown_icon"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </LinearLayout>

<!--        </androidx.constraintlayout.widget.ConstraintLayout>-->
    </LinearLayout>


    <LinearLayout
        android:id="@+id/recyclersecond"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:foreground="@drawable/ripple"
        android:background="@drawable/client_sceen_3_box"
        android:orientation="horizontal"
        android:paddingBottom="2dp"
        android:paddingStart="@dimen/padding_ten"
        android:paddingEnd="@dimen/padding_ten"
        app:layout_constraintTop_toTopOf="parent"
        tools:layout_editor_absoluteX="15dp">

        <LinearLayout
            android:id="@+id/call"
            android:clickable="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="@dimen/padding_ten"
            android:paddingBottom="@dimen/padding_ten">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:background="@drawable/white_circular_shape_for_card"
                android:padding="@dimen/padding_ten"
                android:src="@drawable/phone_icon" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/margin_five"
                android:gravity="center"
                android:text="Call"
                android:textColor="@color/white"
                android:textSize="@dimen/text_twelve" />
        </LinearLayout>


        <LinearLayout
            android:id="@+id/message"
            android:clickable="true"
            android:foreground="@drawable/ripple"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="@dimen/padding_ten"
            android:paddingBottom="@dimen/padding_ten">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:background="@drawable/white_circular_shape_for_card"
                android:padding="@dimen/padding_ten"
                android:src="@drawable/message_icon" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/margin_five"
                android:gravity="center"
                android:text="Message"
                android:textColor="@color/white"
                android:textSize="@dimen/text_twelve" />
        </LinearLayout>


        <LinearLayout
            android:id="@+id/direction"
            android:clickable="true"
            android:foreground="@drawable/ripple"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="@dimen/padding_ten"
            android:paddingBottom="@dimen/padding_ten">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:background="@drawable/white_circular_shape_for_card"
                android:padding="@dimen/padding_ten"
                android:src="@drawable/direction_icon" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/margin_five"
                android:gravity="center"
                android:text="Direction"
                android:textColor="@color/white"
                android:textSize="@dimen/text_twelve" />
        </LinearLayout>

        <ImageView
            android:id="@+id/up_menu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:src="@drawable/uppward_icon" />

    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>