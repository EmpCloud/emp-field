<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:id="@+id/linearLayout5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/margin_ten"
        android:paddingEnd="@dimen/margin_five"
        android:layout_marginEnd="@dimen/margin_five"
        android:orientation="horizontal"
        android:background="@color/white"
        android:paddingTop="@dimen/margin_fifteen"
        android:paddingBottom="@dimen/margin_fifteen"
        app:layout_constraintTop_toTopOf="parent"
        tools:layout_editor_absoluteX="5dp">

        <TextView
            android:id="@+id/date"
            android:layout_width="70dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="start"
            android:text="10-10-23"
            android:textStyle="bold"
            android:textColor="@color/welcome_text_display_color"
            android:textSize="@dimen/text_twelve"
            android:theme="@style/FontMedium" />

        <TextView
            android:id="@+id/leave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:gravity="center"
            android:text="EL"
            android:textAllCaps="false"
            android:textColor="@color/welcome_text_display_color"
            android:textSize="@dimen/text_twelve" />

        <TextView
            android:id="@+id/dataType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Full Day"
            android:theme="@style/FontMedium"
            android:textColor="@color/welcome_text_display_color"
            android:textSize="@dimen/text_twelve" />

        <TextView
            android:id="@+id/day"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:gravity="center"
            android:layout_marginStart="@dimen/margin_five"
            android:text="1Day"
            android:textColor="@color/welcome_text_display_color"
            android:theme="@style/FontMedium"
            android:textSize="@dimen/text_twelve" />


        <TextView
            android:id="@+id/status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:gravity="start"
            android:text="Approved"
            android:textColor="@color/green_listitem_color"
            android:textSize="@dimen/text_twelve" />


<!--        This textview is used for PENDING text where visibility set to gone-->
<!--        in logic change accordingly.-->
        <TextView
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:layout_weight="1"
            android:gravity="start"
            android:text="Pending"
            android:textColor="@color/yellow_text_color"
            android:textSize="@dimen/text_twelve" />

        <ImageView
            android:id="@+id/editLeave"
            android:clickable="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:src="@drawable/edit_icon" />



    </LinearLayout>

    <View
        android:id="@+id/viewdivider"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout5"
        android:background="@color/weekoff"
        tools:layout_editor_absoluteX="0dp" />

</androidx.constraintlayout.widget.ConstraintLayout>