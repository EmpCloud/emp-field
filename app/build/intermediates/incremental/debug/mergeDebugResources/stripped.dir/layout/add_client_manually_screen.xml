<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@drawable/profile_background"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/linearLayout2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_twenty"
        android:layout_marginStart="@dimen/text_fifteen"
        android:layout_marginEnd="@dimen/margin_fifteen"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">


        <androidx.cardview.widget.CardView
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="20dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/arrow_back" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Create Profile"
            android:textColor="@color/white"
            android:textSize="@dimen/text_twenty"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>


    <RelativeLayout
        android:id="@+id/relativeLayout"
        android:layout_width="115dp"
        android:layout_height="115dp"
        android:layout_marginTop="@dimen/margin_twenty"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout2">

        <LinearLayout
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_centerInParent="true"
            android:background="@drawable/user_profile_background"
            android:gravity="center">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/icon_user_profile" />
        </LinearLayout>


        <LinearLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentBottom="true"
            android:gravity="center"
            android:background="@drawable/user_image_upload_back"
            android:layout_alignParentEnd="true">
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@drawable/icon_camera"/>
        </LinearLayout>

    </RelativeLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        android:layout_marginStart="@dimen/margin_fifteen"
        android:layout_marginEnd="@dimen/margin_fifteen"
        android:layout_marginTop="@dimen/margin_twenty"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/relativeLayout">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="@dimen/margin_hundred"
            android:orientation="vertical">
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_twenty"
                    android:layout_marginEnd="@dimen/margin_twenty"
                    android:layout_marginTop="@dimen/margin_twenty"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_fifteen"
                        android:theme="@style/FontMedium"
                        android:textStyle="bold"
                        android:textColor="@color/user_form_text_color"
                        android:text="Full Name*"/>

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_ten"
                        android:background="@drawable/user_screen_edittext_bg"
                        android:hint="Enter Your Name"
                        android:inputType="text"
                        android:theme="@style/FontMedium"
                        android:paddingTop="@dimen/padding_ten"
                        android:paddingBottom="@dimen/padding_ten"
                        android:paddingStart="@dimen/padding_ten"
                        android:textSize="12sp"
                        android:textColor="@color/edit_text_black_color"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_fifteen"
                        android:layout_marginTop="@dimen/margin_twenty"
                        android:theme="@style/FontMedium"
                        android:textStyle="bold"
                        android:textColor="@color/user_form_text_color"
                        android:text="Email ID*"/>

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_ten"
                        android:background="@drawable/user_screen_edittext_bg"
                        android:hint="Enter Email ID"
                        android:inputType="textEmailAddress"
                        android:theme="@style/FontMedium"
                        android:paddingTop="@dimen/padding_ten"
                        android:paddingBottom="@dimen/padding_ten"
                        android:paddingStart="@dimen/padding_ten"
                        android:textSize="12sp"
                        android:textColor="@color/edit_text_black_color"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_twenty"
                        android:textSize="@dimen/text_fifteen"
                        android:theme="@style/FontMedium"
                        android:textStyle="bold"
                        android:textColor="@color/user_form_text_color"
                        android:text="Mobile No.*"/>

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_ten"
                        android:background="@drawable/user_screen_edittext_bg"
                        android:hint="Enter Mobile No"
                        android:inputType="phone"
                        android:theme="@style/FontMedium"
                        android:paddingTop="@dimen/padding_ten"
                        android:paddingBottom="@dimen/padding_ten"
                        android:paddingStart="@dimen/padding_ten"
                        android:textSize="12sp"
                        android:textColor="@color/edit_text_black_color"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_twenty"
                        android:textSize="@dimen/text_fifteen"
                        android:theme="@style/FontMedium"
                        android:textStyle="bold"
                        android:textColor="@color/user_form_text_color"
                        android:text="Client ID"/>

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_ten"
                        android:background="@drawable/user_screen_edittext_bg"
                        android:hint="Enter client  ID"
                        android:inputType="number"
                        android:theme="@style/FontMedium"
                        android:paddingTop="@dimen/padding_ten"
                        android:paddingBottom="@dimen/padding_ten"
                        android:paddingStart="@dimen/padding_ten"
                        android:textSize="12sp"
                        android:textColor="@color/edit_text_black_color"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_twenty"
                        android:textSize="@dimen/text_fifteen"
                        android:theme="@style/FontMedium"
                        android:textStyle="bold"
                        android:textColor="@color/user_form_text_color"
                        android:text="Categories"/>

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_ten"
                        android:background="@drawable/user_screen_edittext_bg"
                        android:hint="Enter client  ID"
                        android:inputType="text"
                        android:theme="@style/FontMedium"
                        android:paddingTop="@dimen/padding_ten"
                        android:paddingBottom="@dimen/padding_ten"
                        android:paddingStart="@dimen/padding_ten"
                        android:textSize="12sp"
                        android:textColor="@color/edit_text_black_color"/>


                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_twenty"
                        android:textSize="@dimen/text_fifteen"
                        android:theme="@style/FontMedium"
                        android:textStyle="bold"
                        android:textColor="@color/user_form_text_color"
                        android:text="Address*"/>

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="65dp"
                        android:layout_gravity="start"
                        android:gravity="start"
                        android:layout_marginTop="@dimen/padding_ten"
                        android:background="@drawable/user_screen_edittext_bg"
                        android:hint="Enter Address"
                        android:inputType="textMultiLine"
                        android:theme="@style/FontMedium"
                        android:paddingTop="@dimen/padding_ten"
                        android:paddingBottom="@dimen/padding_ten"
                        android:paddingStart="@dimen/padding_ten"
                        android:textSize="12sp"
                        android:textColor="@color/edit_text_black_color"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_twenty"
                        android:textSize="@dimen/text_fifteen"
                        android:theme="@style/FontMedium"
                        android:textStyle="bold"
                        android:textColor="@color/user_form_text_color"
                        android:text="City*"/>

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="start"
                        android:gravity="start"
                        android:layout_marginTop="@dimen/padding_ten"
                        android:background="@drawable/user_screen_edittext_bg"
                        android:hint="Enter Address"
                        android:inputType="text"
                        android:theme="@style/FontMedium"
                        android:paddingTop="@dimen/padding_ten"
                        android:paddingBottom="@dimen/padding_ten"
                        android:paddingStart="@dimen/padding_ten"
                        android:textSize="12sp"
                        android:textColor="@color/edit_text_black_color"/>


                </LinearLayout>

            </ScrollView>

<!--            DISABLE BUTOTN DESIGN-->

            <LinearLayout
                android:id="@+id/nextBtn3"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginStart="@dimen/margin_fifteen"
                android:layout_marginTop="@dimen/margin_thirty"
                android:layout_marginEnd="@dimen/margin_fifteen"
                android:background="@drawable/butoon_bg_shape_disabled"
                android:clickable="true"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="Add Client"
                    android:textColor="@color/white"
                    android:textSize="@dimen/button_text_size"
                    android:theme="@style/FontMedium" />
            </LinearLayout>

<!--            ACTIVE BUTTON DESIGN WHERE VISIBILITY SET TO GONE-->

            <LinearLayout
                android:visibility="gone"
                android:id="@+id/nextBtn4"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginStart="@dimen/margin_fifteen"
                android:layout_marginTop="@dimen/margin_thirty"
                android:layout_marginEnd="@dimen/margin_fifteen"
                android:background="@drawable/butoon_bg_shape"
                android:clickable="true"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="Add Client"
                    android:textColor="@color/white"
                    android:textSize="@dimen/button_text_size"
                    android:theme="@style/FontMedium" />
            </LinearLayout>
        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>