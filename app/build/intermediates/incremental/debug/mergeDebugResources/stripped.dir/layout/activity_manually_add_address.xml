<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:background="@drawable/profile_background"
    android:layout_height="match_parent"
    tools:context=".ui.activity.mapaddress.ManuallyAddAddressActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/linearLayout2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_twenty"
        android:layout_marginStart="@dimen/text_fifteen"
        android:layout_marginEnd="@dimen/margin_fifteen"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">


        <androidx.cardview.widget.CardView
            android:id="@+id/backbtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="20dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/baseline_arrow_back_24" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/create_profile"
            android:textColor="@color/white"
            android:textSize="@dimen/text_twenty"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <RelativeLayout
        android:id="@+id/relativeLayout"
        android:layout_width="115dp"
        android:layout_height="115dp"
        android:layout_marginTop="@dimen/margin_twenty"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout2">
        <androidx.cardview.widget.CardView
            android:layout_width="100dp"
            android:layout_height="100dp"
            app:cardCornerRadius="50dp"
            android:gravity="center"
            android:layout_centerInParent="true"
            android:background="@drawable/user_profile_background">
            <ImageView
                android:id="@+id/userPic"
                android:visibility="gone"
                android:scaleType="centerCrop"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/icon_user_profile" />
            <ImageView
                android:id="@+id/userPicdisbale"
                android:visibility="visible"
                android:layout_gravity="center"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:src="@drawable/userprofile_icon" />
        </androidx.cardview.widget.CardView>


<!--        <LinearLayout-->
<!--            android:id="@+id/cameraProfile"-->
<!--            android:clickable="true"-->
<!--            android:layout_width="40dp"-->
<!--            android:layout_height="40dp"-->
<!--            android:translationZ="2dp"-->
<!--            android:layout_alignParentBottom="true"-->
<!--            android:gravity="center"-->
<!--            android:background="@drawable/user_image_upload_back"-->
<!--            android:layout_alignParentEnd="true">-->
<!--            <ImageView-->
<!--                android:layout_width="wrap_content"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:layout_gravity="center"-->
<!--                android:src="@drawable/icon_camera"/>-->
<!--        </LinearLayout>-->

    </RelativeLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/margin_fifteen"
        android:layout_marginTop="@dimen/margin_twenty"
        android:layout_marginEnd="@dimen/margin_fifteen"
        android:layout_marginBottom="@dimen/margin_thirty"
        app:cardCornerRadius="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/relativeLayout">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/margin_hundred">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_twenty"
                    android:layout_marginTop="@dimen/margin_twenty"
                    android:layout_marginEnd="@dimen/margin_twenty"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/add_complete_address"
                        android:textColor="@color/user_form_text_color"
                        android:textSize="@dimen/text_fifteen"
                        android:textStyle="bold"
                        android:theme="@style/FontMedium" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_twenty"
                        android:text="@string/address_line_1"
                        android:textColor="@color/radio_button_text_color"
                        android:textSize="@dimen/text_twelve"
                        android:textStyle="bold"
                        android:theme="@style/FontMedium" />

                    <EditText
                        android:id="@+id/addressfirst"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_five"
                        android:background="@drawable/user_screen_edittext_bg"
                        android:inputType="textMultiLine"
                        android:paddingStart="@dimen/padding_ten"
                        android:paddingTop="@dimen/padding_ten"
                        android:paddingBottom="@dimen/padding_ten"
                        android:textColor="#5F5F5F"
                        android:textSize="12sp"
                        android:theme="@style/FontMedium" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_twenty"
                        android:text="@string/address_line_2"
                        android:textColor="@color/radio_button_text_color"
                        android:textSize="@dimen/text_twelve"
                        android:textStyle="bold"
                        android:theme="@style/FontMedium" />

                    <EditText
                        android:id="@+id/addressSecond"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_five"
                        android:background="@drawable/user_screen_edittext_bg"
                        android:inputType="text"
                        android:paddingStart="@dimen/padding_ten"
                        android:paddingTop="@dimen/padding_ten"
                        android:paddingBottom="@dimen/padding_ten"
                        android:textColor="#5F5F5F"
                        android:textSize="12sp"
                        android:theme="@style/FontMedium" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_twenty"
                        android:text="@string/state"
                        android:textColor="@color/radio_button_text_color"
                        android:textSize="@dimen/text_twelve"
                        android:textStyle="bold"
                        android:theme="@style/FontMedium" />
                    <EditText
                        android:id="@+id/state"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_five"
                        android:background="@drawable/user_screen_edittext_bg"
                        android:inputType="text"
                        android:paddingStart="@dimen/padding_ten"
                        android:paddingTop="@dimen/padding_ten"
                        android:paddingBottom="@dimen/padding_ten"
                        android:textColor="#5F5F5F"
                        android:textSize="12sp"
                        android:theme="@style/FontMedium" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_twenty"
                        android:text="@string/city"
                        android:textColor="@color/radio_button_text_color"
                        android:textSize="@dimen/text_twelve"
                        android:textStyle="bold"
                        android:theme="@style/FontMedium" />

                    <EditText
                        android:id="@+id/city"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_five"
                        android:background="@drawable/user_screen_edittext_bg"
                        android:inputType="text"
                        android:paddingStart="@dimen/padding_ten"
                        android:paddingTop="@dimen/padding_ten"
                        android:paddingBottom="@dimen/padding_ten"
                        android:textColor="#5F5F5F"
                        android:textSize="12sp"
                        android:theme="@style/FontMedium" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_twenty"
                        android:text="@string/zip_code"
                        android:textColor="@color/radio_button_text_color"
                        android:textSize="@dimen/text_twelve"
                        android:textStyle="bold"
                        android:theme="@style/FontMedium" />
                    <EditText
                        android:id="@+id/zip"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="100dp"
                        android:layout_marginTop="@dimen/margin_five"
                        android:background="@drawable/user_screen_edittext_bg"
                        android:inputType="number"
                        android:paddingStart="@dimen/padding_ten"
                        android:paddingTop="@dimen/padding_ten"
                        android:paddingBottom="@dimen/padding_ten"
                        android:textColor="#5F5F5F"
                        android:textSize="12sp"
                        android:theme="@style/FontMedium" />

                </LinearLayout>

            </ScrollView>

        </LinearLayout>
        <LinearLayout
            android:id="@+id/submitbtn"
            android:layout_width="match_parent"
            android:layout_height="@dimen/user_screen_button_height"
            android:layout_marginStart="@dimen/margin_twenty"
            android:layout_marginEnd="@dimen/margin_twenty"
            android:layout_marginBottom="@dimen/margin_twenty"
            android:foreground="@drawable/ripple"
            android:background="@drawable/butoon_bg_shape"
            android:layout_gravity="bottom"
            android:clickable="true"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:theme="@style/FontMedium"
                android:gravity="center"
                android:text="@string/submit"
                android:textColor="@color/white"
                android:textSize="@dimen/button_text_size" />
        </LinearLayout>


    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>