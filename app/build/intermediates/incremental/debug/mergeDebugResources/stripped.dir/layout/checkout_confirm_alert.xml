<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:id="@+id/customeAlertcheckout"
    android:visibility="gone"
    android:translationZ="20dp"
    android:clickable="true"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#3279B2FF"
    android:layout_height="match_parent">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/white"
        android:layout_marginStart="@dimen/margin_twenty"
        android:layout_marginEnd="@dimen/margin_twenty"
        app:cardCornerRadius="@dimen/margin_twenty"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/cancelbtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/margin_ten"
                android:layout_marginTop="@dimen/margin_ten"
                android:src="@drawable/cancel_icon"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="@dimen/margin_twenty"
            android:layout_marginBottom="@dimen/margin_twenty"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/logout_alert"
                android:textColor="@color/black"
                android:layout_marginStart="@dimen/margin_twenty"
                android:theme="@style/monstreat_semibold"
                android:textSize="@dimen/text_sixteen"/>


            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_twenty"
                android:layout_marginEnd="@dimen/margin_twenty"
                android:layout_marginTop="@dimen/margin_ten"
                android:layout_gravity="center"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/proceeding_further_will_stop_your_live_location_tracking_and_you_ll_be_checked_out_for_the_day"
                    android:textColor="#000000"
                    android:theme="@style/MonstratLight"
                    android:textSize="@dimen/text_twelve"/>


            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_twenty"
                android:layout_marginTop="@dimen/margin_twenty"
                android:layout_gravity="start"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/please_confirm_your_action"
                    android:textColor="@color/black"
                    android:theme="@style/monstreat_semibold"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:textSize="@dimen/text_twelve"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:layout_marginTop="@dimen/margin_twenty"
                android:layout_marginStart="@dimen/margin_twenty"
                android:layout_marginEnd="@dimen/margin_twenty"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/abortbtn"
                    android:layout_width="wrap_content"
                    android:foreground="@drawable/ripple_new_aman"
                    android:background="@drawable/add_leave_bg"
                    android:layout_gravity="center"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/abort"
                        android:theme="@style/FontMedium"
                        android:fontFamily="@font/montserrat_semibold"
                        android:paddingStart="@dimen/margin_thirty"
                        android:paddingEnd="@dimen/margin_thirty"
                        android:paddingTop="@dimen/padding_ten"
                        android:paddingBottom="@dimen/padding_ten"
                        android:textSize="@dimen/text_twelve"
                        android:textColor="@color/buttonbgcolor"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/okayBtn"
                    android:layout_width="wrap_content"
                    android:layout_marginStart="@dimen/margin_twenty"
                    android:foreground="@drawable/ripple_new_aman"
                    android:background="@drawable/checkout_confirmbtn_bg"
                    android:layout_gravity="center"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="@dimen/margin_twenty"
                        android:paddingEnd="@dimen/margin_twenty"
                        android:text="@string/yes_check_me_out"
                        android:theme="@style/FontMedium"
                        android:fontFamily="@font/montserrat_semibold"
                        android:paddingTop="@dimen/padding_ten"
                        android:paddingBottom="@dimen/padding_ten"
                        android:textSize="@dimen/text_twelve"
                        android:textColor="@color/white"/>
                </LinearLayout>

            </LinearLayout>


        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>