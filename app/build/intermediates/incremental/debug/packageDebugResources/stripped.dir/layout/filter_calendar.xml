<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clickable="true"
    android:translationZ="50dp"
    android:visibility="gone"
    android:id="@+id/popUpDateandTime"
    android:background="#80BFD8FA">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/margin_twenty"
        android:layout_marginEnd="@dimen/margin_twenty"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:cardCornerRadius="@dimen/margin_ten">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:translationZ="50dp">

            <ImageView
                android:id="@+id/cancelbtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/margin_ten"
                android:layout_marginTop="@dimen/margin_five"
                android:layout_gravity="end"
                android:adjustViewBounds="true"
                android:clickable="true"
                android:scaleType="centerCrop"
                android:src="@drawable/cancel_icon"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/white"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="16dp">

            <CalendarView
                android:id="@+id/calendarView"
                android:theme="@style/CustomTimePickerDialog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <LinearLayout
                android:id="@+id/okayBtn"
                android:clickable="true"
                android:foreground="@drawable/ripple"
                android:layout_width="wrap_content"
                android:background="@drawable/butoon_bg_shape"
                android:layout_marginTop="@dimen/margin_twenty"
                android:layout_gravity="end"
                android:layout_marginEnd="@dimen/margin_ten"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OK"
                    android:fontFamily="@font/montserrat_semibold"
                    android:paddingStart="@dimen/margin_twenty"
                    android:paddingEnd="@dimen/margin_twenty"
                    android:paddingTop="@dimen/padding_ten"
                    android:paddingBottom="@dimen/margin_ten"
                    android:textSize="@dimen/text_twelve"
                    android:textColor="@color/white"/>
            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>