<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.fragment.task.select_client_3.SelectClientFragment">

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:translationZ="30dp"
        android:indeterminateDrawable="@drawable/progressbar_bg"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/constraintLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_twenty"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        tools:layout_editor_absoluteX="15dp">

        <!--        back arrow view-->
        <androidx.cardview.widget.CardView
            android:id="@+id/backbtn"
            android:clickable="true"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="@dimen/margin_twenty"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="15dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:padding="3dp"
                android:layout_gravity="center"
                android:src="@drawable/baseline_arrow_back_24" />
        </androidx.cardview.widget.CardView>


        <TextView
            android:id="@+id/textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="@string/select_client"
            android:textColor="@color/white"
            android:textSize="@dimen/text_twenty"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />



    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/linearLayout8"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/margin_twenty"
        android:background="@drawable/profile_back_shape"
        android:elevation="10dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/constraintLayout">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/linearLayout10"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="@dimen/margin_twenty"
                android:layout_marginEnd="@dimen/margin_fifty"
                android:layout_marginStart="@dimen/margin_fifty"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <EditText
                    android:id="@+id/search"
                    android:textCursorDrawable="@null"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/blue_shape_color"
                    android:drawableStart="@drawable/task_search_icon"
                    android:drawablePadding="@dimen/padding_ten"
                    android:hint="@string/search"
                    android:paddingStart="@dimen/padding_ten"
                    android:paddingTop="@dimen/padding_ten"
                    android:paddingEnd="@dimen/padding_twenty"
                    android:paddingBottom="@dimen/padding_ten"
                    android:textColor="@color/white"
                    android:textColorHint="@color/white"
                    android:textSize="@dimen/text_twelve"
                    android:theme="@style/FontMedium" />

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/selectClientRecycler"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_margin="@dimen/margin_twenty"
                app:layout_constraintBottom_toTopOf="@+id/disbalebtn"
                app:layout_constraintTop_toBottomOf="@+id/linearLayout10"
                tools:layout_editor_absoluteX="15dp"
                tools:listitem="@layout/task_listitems_screen" />


            <!--        THIS IS DISABLED BUTTON DESIGN -->
            <LinearLayout
                android:id="@+id/linearLayout11"
                android:layout_width="match_parent"
                android:layout_height="@dimen/user_screen_button_height"
                android:layout_gravity="bottom"
                android:layout_margin="@dimen/margin_twenty"
                android:background="@drawable/butoon_bg_shape_disabled"
                android:clickable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:translationZ="10dp"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="Submit"
                    android:textColor="@color/white"
                    android:textSize="@dimen/button_text_size"
                    android:theme="@style/FontMedium" />
            </LinearLayout>

            <!--        THIS IS ACTIVE BUTTON DESIGN WHERE VISIBILITY SET TO GONE USE ACCORDINGLY LOGIC-->

            <LinearLayout
                android:id="@+id/disbalebtn"
                android:visibility="visible"
                android:layout_width="match_parent"
                android:layout_height="@dimen/user_screen_button_height"
                android:layout_gravity="bottom"
                android:layout_marginBottom="@dimen/margin_thirty"
                android:translationZ="10dp"
                android:background="@drawable/butoon_bg_shape_disabled"
                android:clickable="true"
                android:gravity="center"
                android:layout_margin="@dimen/margin_twenty"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="@string/select_client"
                    android:textColor="@color/white"
                    android:textSize="@dimen/button_text_size"
                    android:theme="@style/FontMedium" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/enablebtn"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="@dimen/user_screen_button_height"
                android:layout_gravity="bottom"
                android:layout_marginBottom="@dimen/margin_thirty"
                android:translationZ="10dp"
                android:background="@drawable/butoon_bg_shape"
                android:clickable="true"
                android:gravity="center"
                android:layout_margin="@dimen/margin_twenty"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="@string/select_client"
                    android:textColor="@color/white"
                    android:textSize="@dimen/button_text_size"
                    android:theme="@style/FontMedium" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>


    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>