<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:id="@+id/containerTags"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_fifteen"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.cardview.widget.CardView
            android:id="@+id/statusiconcard"
            android:layout_width="8dp"
            android:layout_height="8dp"
            app:cardElevation="0dp"
            app:cardCornerRadius="4dp"
            android:layout_gravity="center"
            android:layout_marginStart="@dimen/margin_twenty"
            app:cardBackgroundColor="@color/yellow_text_color"/>

        <TextView
            android:id="@+id/stagestaustxt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_ten"
            android:layout_gravity="center"
            android:text="Pending"
            android:textColor="@color/stage_recyvler_itemslist_txt"
            android:theme="@style/FontMedium"
            android:textSize="@dimen/text_twelve"/>


    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>