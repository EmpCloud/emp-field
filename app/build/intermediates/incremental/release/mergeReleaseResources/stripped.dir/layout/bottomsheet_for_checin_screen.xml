<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:clickable="true"
    android:orientation="vertical"
    android:background="@color/white"
    android:translationZ="10dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/margin_fifteen"
        android:layout_marginEnd="@dimen/margin_fifteen"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        tools:layout_editor_absoluteX="15dp">

        <TextView
            android:id="@+id/currentDay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_ten"
            android:layout_gravity="center"
            android:theme="@style/UbuntuRegular"
            android:gravity="center"
            android:text="Wed, Oct 4"
            android:textColor="#1069BC"
            android:textSize="@dimen/text_twenty" />

        <TextView
            android:id="@+id/currentTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_ten"
            android:layout_gravity="center"
            android:theme="@style/UbuntuRegular"
            android:gravity="center"
            android:text="09:55am"
            android:textColor="#1069BC"
            android:textSize="@dimen/text_sixteen" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_twenty"
            android:layout_marginEnd="@dimen/margin_twenty"
            android:layout_marginTop="@dimen/margin_ten"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="@dimen/padding_ten"
                android:paddingBottom="@dimen/padding_ten"
                android:layout_weight="1"
                android:background="@drawable/checkin_light_color_box_shape"
                android:orientation="vertical">
                <CheckBox
                    android:id="@+id/inCheckBox"
                    android:focusable="false"
                    android:clickable="false"
                    android:layout_width="wrap_content"
                    android:layout_height="25dp"
                    android:layout_gravity="center"
                    android:text="IN Time"
                    android:theme="@style/UbuntuRegular"
                    android:textSize="@dimen/margin_ten" />

                <TextView
                    android:id="@+id/inTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:theme="@style/UbuntuRegular"
                    android:gravity="center"
                    android:text="-- --"
                    android:textColor="@color/black_text_color"
                    android:textSize="@dimen/text_twenty" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="@dimen/padding_ten"
                android:paddingTop="@dimen/padding_ten"
                android:layout_weight="1"
                android:background="@drawable/records_common_back_shape"
                android:orientation="vertical">
                <CheckBox
                    android:id="@+id/outCheck"
                    android:focusable="false"
                    android:clickable="false"
                    android:layout_width="wrap_content"
                    android:layout_height="25dp"
                    android:layout_gravity="center"
                    android:text="OUT Time"
                    android:theme="@style/UbuntuRegular"
                    android:textSize="@dimen/margin_ten"/>

                <TextView
                    android:id="@+id/outTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:theme="@style/UbuntuRegular"
                    android:gravity="center"
                    android:text="-- --"
                    android:textColor="@color/black_text_color"
                    android:textSize="@dimen/text_twenty" />

            </LinearLayout>



        </LinearLayout>
