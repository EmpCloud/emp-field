        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_ten"
            android:layout_marginStart="@dimen/margin_fifty"
            android:layout_marginEnd="@dimen/margin_fifty">

            <com.ncorti.slidetoact.SlideToActView
                android:id="@+id/sliderActView"
                android:layout_width="match_parent"
                android:visibility="gone"
                android:layout_height="50dp"
                app:inner_color="@color/swipe_innercolor"
                app:animation_duration="250"
                app:border_radius="120dp"
                android:layout_marginStart="@dimen/margin_twenty"
                android:layout_marginEnd="@dimen/margin_twenty"
                app:icon_margin="8dp"
                app:slider_icon="@drawable/baseline_arrow_forward_24"
                app:text="Swipe to Check IN"
                app:text_color="@color/swipe_text"
                app:outer_color="@color/swipe_outercolor"
                android:layout_margin="10dp"
                app:slider_locked="false"
                app:text_size="12sp" />

            <TextView
                android:id="@+id/autoCheckInText"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:visibility="gone"
                android:gravity="center"
                android:text="Swipe to Auto Check In"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/transport_selection_bg"
                android:layout_marginStart="@dimen/margin_twenty"
                android:layout_marginEnd="@dimen/margin_twenty"
                android:layout_margin="10dp" />

            <ImageView
                android:id="@+id/swipeDisable"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:adjustViewBounds="true"
                android:layout_marginStart="@dimen/margin_twenty"
                android:layout_marginEnd="@dimen/margin_twenty"
                android:src="@drawable/swipe"/>

            <ImageView
                android:id="@+id/swipeDisablecheckout"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:adjustViewBounds="true"
                android:layout_marginStart="@dimen/margin_twenty"
                android:layout_marginEnd="@dimen/margin_twenty"
                android:src="@drawable/mapswipecheckout"/>
        </LinearLayout>


    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>