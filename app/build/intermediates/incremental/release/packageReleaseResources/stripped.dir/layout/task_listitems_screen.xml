<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">


        <LinearLayout
            android:id="@+id/card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="@dimen/margin_fifteen"
            android:paddingBottom="@dimen/margin_fifteen"
            android:layout_marginStart="@dimen/margin_ten"
            android:layout_marginEnd="@dimen/margin_ten"
            android:layout_gravity="center"
            android:background="@drawable/edit_text_back"
            android:paddingEnd="@dimen/padding_ten"
            android:paddingStart="@dimen/padding_ten"
            android:layout_margin="@dimen/margin_five"
            android:orientation="horizontal">


              <ImageView
                  android:id="@+id/userImg"
                  android:visibility="visible"
                  android:layout_width="40dp"
                  android:layout_height="40dp"
                  android:adjustViewBounds="true"
                  android:layout_gravity="center"
                  android:scaleType="centerCrop"
                  android:padding="@dimen/padding_ten"
                  android:background="@drawable/gradient_circular_back_shap"
                  android:src="@drawable/icon_user_profile"
                  app:tint="@color/white" />

            <androidx.cardview.widget.CardView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:visibility="gone"
                android:id="@+id/picardselect"
                app:cardCornerRadius="20dp">

                <ImageView
                    android:id="@+id/profilePicselect"
                    android:visibility="visible"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:adjustViewBounds="true"
                    android:scaleType="centerCrop" />

            </androidx.cardview.widget.CardView>

<!--            <androidx.cardview.widget.CardView-->
