<!--                    android:visibility="visible"-->
<!--                    android:layout_gravity="center"-->
<!--                    android:scaleType="centerCrop"-->
<!--                    android:layout_width="match_parent"-->
<!--                    android:layout_height="match_parent"-->
<!--                    android:src="@drawable/icon_user_profile"-->
<!--                    app:tint="@color/white" />-->

<!--                <ImageView-->
<!--                    android:id="@+id/userPicdisbale"-->
<!--                    android:visibility="visible"-->
<!--                    android:layout_gravity="center"-->
<!--                    android:layout_width="wrap_content"-->
<!--                    android:layout_height="wrap_content"-->
<!--                    app:tint="@color/white"-->
<!--                    android:src="@drawable/icon_user_profile" />-->
<!--            </androidx.cardview.widget.CardView>-->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_gravity="center"
                android:layout_marginStart="@dimen/margin_ten"
                android:orientation="vertical">

                <TextView
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:id="@+id/clientNameSelect"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Aman Singh"
                    android:gravity="start"
                    android:textColor="@color/grey_text_color"
                    android:textSize="@dimen/text_fifteen" />

                <TextView
                    android:id="@+id/clientAddressSelect"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="start"
                    android:text="devansh@gmail.com"
                    android:textColor="@color/grey_text_color"
                    android:theme="@style/FontMedium"
                    android:textSize="@dimen/text_twelve" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_gravity="center"
                android:gravity="end">
                <TextView
                    android:id="@+id/distanceSelect"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/margin_ten"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="--"
                    android:textSize="@dimen/text_twelve"
                    android:textColor="@color/welcome_text_display_color"/>

<!--                THIS IS FOR GREEN LOCATION -->
                
                <ImageView
                    android:id="@+id/greenLOc"
                    android:visibility="visible"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@drawable/green_loc_back_shape"
                    android:padding="@dimen/margin_five"
                    android:src="@drawable/baseline_location_on_24"
                    android:layout_gravity="center"/>

<!--                THIS IS FOR RED LOCATION WHERE VISIBILITY SET TO GONE-->

                <ImageView
                    android:id="@+id/redLoc"
                    android:visibility="gone"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@drawable/red_loc_back_shape"
                    android:padding="@dimen/margin_five"
                    android:src="@drawable/baseline_location_on_24"
                    android:layout_gravity="center"/>

            </LinearLayout>

        </LinearLayout>

</LinearLayout>