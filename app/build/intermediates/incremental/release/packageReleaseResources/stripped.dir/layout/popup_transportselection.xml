<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/poptransport"
    android:layout_width="match_parent"
    android:background="#3279B2FF"
    android:translationZ="20dp"
    android:clickable="true"
    android:visibility="gone"
    android:layout_height="match_parent">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="@dimen/margin_fifteen"
        app:cardBackgroundColor="@color/white"
        android:layout_marginStart="@dimen/margin_fifteen"
        android:layout_marginEnd="@dimen/margin_fifteen"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/_1470c6"
                android:text="@string/select_mode_of_transportation"
                android:textSize="@dimen/text_fourteen"
                android:theme="@style/FontMedium"
                android:layout_gravity="center"
                android:gravity="center"
                android:layout_marginTop="@dimen/margin_twenty"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_twenty"
                android:layout_marginBottom="@dimen/margin_twenty"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/bike"
                    android:layout_weight="1"
                    android:paddingStart="@dimen/margin_five"
                    android:paddingEnd="@dimen/margin_five"
                    android:layout_marginStart="@dimen/margin_ten"
                    android:layout_marginEnd="@dimen/margin_five"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/add_leave_bg"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="25dp"
                        android:src="@drawable/bike"
                        android:layout_gravity="center"
                        android:scaleType="centerCrop"
                        android:adjustViewBounds="true"
                        android:layout_margin="@dimen/margin_five"
                        android:layout_height="25dp"/>

                    <TextView
                        android:id="@+id/textbike"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/margin_ten"
                        android:textColor="@color/new_txt_3a"
                        android:text="@string/bike"
                        android:textSize="12sp"
                        android:theme="@style/FontMedium"
                        android:layout_gravity="center"
                        android:gravity="center"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/car"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/margin_five"
                    android:layout_marginEnd="@dimen/margin_five"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="@dimen/margin_five"
                    android:paddingEnd="@dimen/margin_five"
                    android:background="@drawable/add_leave_bg"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="25dp"
                        android:src="@drawable/carselection"
                        android:layout_gravity="center"
                        android:scaleType="centerCrop"
                        android:adjustViewBounds="true"
                        android:layout_margin="@dimen/margin_five"
                        android:layout_height="25dp"/>

                    <TextView
                        android:id="@+id/textcar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/new_txt_3a"
                        android:text="@string/car"
                        android:textSize="@dimen/_12sp"
                        android:theme="@style/FontMedium"
                        android:layout_gravity="center"
                        android:gravity="center"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/auto"
                    android:layout_marginStart="@dimen/margin_five"
                    android:layout_marginEnd="@dimen/margin_ten"
                    android:layout_weight="1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="@dimen/margin_five"
                    android:paddingEnd="@dimen/margin_five"
                    android:background="@drawable/add_leave_bg"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="25dp"
                        android:src="@drawable/auto"
                        android:layout_gravity="center"
                        android:scaleType="centerCrop"
                        android:adjustViewBounds="true"
                        android:layout_margin="@dimen/margin_five"
                        android:layout_height="25dp"/>

                    <TextView
                        android:id="@+id/textauto"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/margin_ten"
                        android:textColor="@color/new_txt_3a"
                        android:text="Auto"
                        android:textSize="@dimen/_12sp"
                        android:theme="@style/FontMedium"
                        android:layout_gravity="center"
                        android:gravity="center"/>
                </LinearLayout>
            </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/margin_twenty"
            android:layout_gravity="center"
            android:gravity="start"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/bus"
                android:layout_marginStart="@dimen/margin_ten"
                android:layout_marginEnd="@dimen/margin_five"
                android:layout_width="95dp"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/margin_five"
                android:paddingEnd="@dimen/margin_five"
                android:background="@drawable/add_leave_bg"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="25dp"
                    android:src="@drawable/bus"
                    android:layout_gravity="center"
                    android:scaleType="centerCrop"
                    android:adjustViewBounds="true"
                    android:layout_margin="@dimen/margin_five"
                    android:layout_height="25dp"/>

                <TextView
                    android:id="@+id/textbus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/margin_ten"
                    android:textColor="@color/new_txt_3a"
                    android:text="@string/bus"
                    android:textSize="@dimen/_12sp"
                    android:theme="@style/FontMedium"
                    android:layout_gravity="center"
                    android:gravity="center"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rail"
                android:layout_marginStart="@dimen/margin_five"
                android:layout_marginEnd="@dimen/margin_ten"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/margin_five"
                android:paddingEnd="@dimen/margin_five"
                android:background="@drawable/add_leave_bg"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="25dp"
                    android:src="@drawable/train"
                    android:layout_gravity="center"
                    android:scaleType="centerCrop"
                    android:adjustViewBounds="true"
                    android:layout_margin="@dimen/margin_five"
                    android:layout_height="25dp"/>

                <TextView
                    android:id="@+id/textrail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/margin_five"
                    android:textColor="@color/new_txt_3a"
                    android:text="@string/train_metro"
                    android:textSize="@dimen/_12sp"
                    android:theme="@style/FontMedium"
                    android:layout_gravity="center"
                    android:gravity="center"/>
            </LinearLayout>


        </LinearLayout>
            <LinearLayout
                android:id="@+id/selectionbtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_twenty"
                android:layout_gravity="center"
                android:foreground="@drawable/ripple"
                android:background="@drawable/butoon_bg_shape"
                android:clickable="true"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_fifty"
                    android:layout_marginTop="@dimen/margin_ten"
                    android:layout_marginBottom="@dimen/margin_ten"
                    android:layout_marginEnd="@dimen/margin_fifty"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="@string/select"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_twelve"
                    android:theme="@style/FontMedium" />
            </LinearLayout>



        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>