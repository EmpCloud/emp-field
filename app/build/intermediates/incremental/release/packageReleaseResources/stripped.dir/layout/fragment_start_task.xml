    <androidx.cardview.widget.CardView
        android:id="@+id/cardView4"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/margin_twenty"
        app:cardCornerRadius="@dimen/margin_twenty"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/constraintLayout">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="190dp">

            <fragment
                android:id="@+id/map"
                android:name="com.google.android.gms.maps.SupportMapFragment"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:nestedScrollingEnabled="true" />

            <ImageView
                android:id="@+id/center_marker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:adjustViewBounds="true"
                android:src="@drawable/marker_customs" />

            <EditText
                android:id="@+id/search_bar"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginStart="@dimen/margin_fifteen"
                android:layout_marginTop="@dimen/padding_twenty"
                android:layout_marginEnd="@dimen/margin_fifteen"
                android:background="@drawable/map_search_background"
                android:drawableStart="@drawable/baseline_search_24"
                android:drawablePadding="@dimen/padding_ten"
                android:hint="@string/search_for_area_street_name"
                android:paddingStart="@dimen/padding_twenty"
                android:paddingEnd="@dimen/padding_twenty"
                android:textColor="@color/black"
                android:textSize="@dimen/text_twelve"
                android:theme="@style/FontMedium" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/search_results"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/search_bar"
                android:visibility="visible" />


        </RelativeLayout>
    </androidx.cardview.widget.CardView>


    <include
        android:id="@+id/bottomSheet"
        layout="@layout/bottom_start_task_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:behavior_hideable="true"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>


    <include
        android:id="@+id/calendarPopUp"
        layout="@layout/calendar_pop_up_with_time"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:behavior_hideable="true"
        app:layout_constraintBottom_toBottomOf="parent" />

    <include layout="@layout/custom_popup_taskhome"
        android:layout_height="match_parent"
        android:layout_width="match_parent"
        android:id="@+id/customshow"/>

    <include layout="@layout/picprviewlayout"
        android:layout_height="match_parent"
        android:layout_width="match_parent"
        android:id="@+id/picpreview"/>


