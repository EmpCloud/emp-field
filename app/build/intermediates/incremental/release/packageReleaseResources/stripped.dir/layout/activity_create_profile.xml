<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="@drawable/profile_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.activity.createprofile.CreateProfileActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/linearLayout2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_twenty"
        android:layout_marginStart="@dimen/text_fifteen"
        android:layout_marginEnd="@dimen/margin_fifteen"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">


        <androidx.cardview.widget.CardView
            android:id="@+id/backbtn"
            android:clickable="true"
            android:layout_width="30dp"
            android:layout_height="30dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="15dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/baseline_arrow_back_24" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/create_profile"
            android:textColor="@color/white"
            android:textSize="@dimen/text_twenty"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>


    <RelativeLayout
        android:id="@+id/relativeLayout"
        android:layout_width="115dp"
        android:layout_height="115dp"
        android:layout_marginTop="@dimen/margin_twenty"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout2">

        <androidx.cardview.widget.CardView
            android:layout_width="100dp"
            android:layout_height="100dp"
            app:cardCornerRadius="50dp"
            android:layout_centerInParent="true"
            android:background="@drawable/user_profile_background"
            android:gravity="center">

            <ImageView
                android:id="@+id/userPic"
                android:visibility="gone"
                android:layout_gravity="center"
                android:scaleType="centerCrop"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/defalut_user_ico" />

            <ImageView
                android:id="@+id/userPicdisbale"
                android:visibility="visible"
                android:layout_gravity="center"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:src="@drawable/userprofile_icon" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_gravity="center"
                android:visibility="gone"
                android:indeterminateDrawable="@drawable/progressbar_bg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

<!--            <ImageView-->
<!--                android:id="@+id/loading"-->
<!--                android:visibility="gone"-->
<!--                android:layout_gravity="center"-->
<!--                android:layout_width="wrap_content"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:src="@drawable/loading" />-->

        </androidx.cardview.widget.CardView>


        <LinearLayout
            android:id="@+id/cameraProfile"
            android:translationZ="2dp"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentBottom="true"
            android:foreground="@drawable/ripple_fab"
            android:clickable="true"
            android:gravity="center"
            android:background="@drawable/user_image_upload_back"
            android:layout_alignParentEnd="true">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:adjustViewBounds="true"
                android:layout_gravity="center"
                android:src="@drawable/icon_camera" />
        </LinearLayout>

    </RelativeLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/margin_fifteen"
        android:layout_marginTop="@dimen/margin_twenty"
        android:layout_marginEnd="@dimen/margin_fifteen"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="20dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/relativeLayout">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_twenty"
                    android:layout_marginTop="@dimen/margin_twenty"
                    android:layout_marginEnd="@dimen/margin_twenty"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/full_name"
                        android:textColor="@color/user_form_text_color"
                        android:textSize="@dimen/text_fifteen"
                        android:textStyle="bold"
                        android:theme="@style/FontMedium" />

                    <EditText
                        android:id="@+id/name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_ten"
                        android:background="@drawable/user_screen_edittext_bg"
                        android:hint="@string/enter_your_name"
                        android:inputType="text"
                        android:paddingStart="@dimen/padding_ten"
                        android:paddingTop="@dimen/padding_ten"
                        android:paddingBottom="@dimen/padding_ten"
                        android:textColor="#5F5F5F"
                        android:textSize="12sp"
                        android:theme="@style/FontMedium" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_twenty"
                        android:text="@string/email_id_ma"
                        android:textColor="@color/user_form_text_color"
                        android:textSize="@dimen/text_fifteen"
                        android:textStyle="bold"
                        android:theme="@style/FontMedium" />

                    <EditText
                        android:id="@+id/email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_ten"
                        android:background="@drawable/user_screen_edittext_bg"
                        android:hint="@string/enter_email_id"
                        android:inputType="none"
                        android:paddingStart="@dimen/padding_ten"
                        android:paddingTop="@dimen/padding_ten"
                        android:paddingBottom="@dimen/padding_ten"
                        android:textColor="#5F5F5F"
                        android:textSize="12sp"
                        android:theme="@style/FontMedium" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_twenty"
                        android:text="@string/mobile_no_not_rq"
                        android:textColor="@color/user_form_text_color"
                        android:textSize="@dimen/text_fifteen"
                        android:textStyle="bold"
                        android:theme="@style/FontMedium" />

                    <EditText
                        android:id="@+id/mobileNo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_ten"
                        android:background="@drawable/user_screen_edittext_bg"
                        android:hint="@string/enter_mobile_no"
                        android:inputType="number"
                        android:maxLength="18"
                        android:paddingStart="@dimen/padding_ten"
                        android:paddingTop="@dimen/padding_ten"
                        android:paddingBottom="@dimen/padding_ten"
                        android:textColor="#5F5F5F"
                        android:textSize="12sp"
                        android:theme="@style/FontMedium" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_twenty"
                        android:text="@string/select_age"
                        android:textColor="@color/user_form_text_color"
                        android:textSize="@dimen/text_fifteen"
                        android:textStyle="bold"
                        android:theme="@style/FontMedium" />

                    <EditText
                        android:id="@+id/age"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_ten"
                        android:background="@drawable/user_screen_edittext_bg"
                        android:hint="@string/enter_your_age"
                        android:inputType="number"
                        android:maxLength="2"
                        android:paddingStart="@dimen/padding_ten"
                        android:paddingTop="@dimen/padding_ten"
                        android:paddingBottom="@dimen/padding_ten"
                        android:textColor="#5F5F5F"
                        android:textSize="12sp"
                        android:theme="@style/FontMedium" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_twenty"
                        android:text="@string/select_gender"
                        android:textColor="@color/user_form_text_color"
                        android:textSize="@dimen/text_fifteen"
                        android:textStyle="bold"
                        android:theme="@style/FontMedium" />

                    <RadioGroup
                        android:id="@+id/radiogrp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/male"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/margin_twenty"
                            android:text="@string/male"
                            android:textColor="@color/radio_button_text_color"
                            android:textSize="@dimen/text_fourteen"
                            android:theme="@style/UbuntuMedium" />

                        <RadioButton
                            android:id="@+id/female"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/margin_twenty"
                            android:text="@string/female"
                            android:textColor="@color/radio_button_text_color"
                            android:textSize="@dimen/text_fourteen"
                            android:theme="@style/UbuntuMedium" />

                        <RadioButton
                            android:id="@+id/other"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/margin_twenty"
                            android:text="@string/other"
                            android:textColor="@color/radio_button_text_color"
                            android:textSize="@dimen/text_fourteen"
                            android:theme="@style/UbuntuMedium" />

                    </RadioGroup>

                    <View
                        android:id="@+id/view_firstName"
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_marginLeft="@dimen/text_fifteen"
                        android:layout_marginTop="10dp"
                        android:layout_marginRight="@dimen/text_fifteen"
                        android:background="@color/view_horizontal_line_color"
                        />

                    <LinearLayout
                        android:id="@+id/disbalebtn"
                        android:layout_marginBottom="@dimen/margin_fifty"
                        android:layout_width="match_parent"
                        android:layout_height="35dp"
                        android:layout_marginStart="@dimen/margin_fifty"
                        android:layout_marginTop="@dimen/text_twenty_five"
                        android:layout_marginEnd="@dimen/margin_fifty"
                        android:background="@drawable/button_bg_user_profile"
                        android:clickable="true"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:visibility="visible"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_bias="0.0"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/linearLayout">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:fontFamily="@font/montserrat_medium"
                            android:gravity="center"
                            android:text="@string/add_address"
                            android:textColor="@color/white"
                            android:textSize="@dimen/text_fifteen" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/truebtn"
                        android:layout_marginBottom="@dimen/margin_fifty"
                        android:layout_width="match_parent"
                        android:layout_height="35dp"
                        android:layout_marginStart="@dimen/margin_fifty"
                        android:layout_marginTop="@dimen/text_twenty_five"
                        android:layout_marginEnd="@dimen/margin_fifty"
                        android:background="@drawable/butoon_bg_shape"
                        android:clickable="true"
                        android:foreground="@drawable/ripple"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:visibility="gone"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_bias="0.0"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/linearLayout">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:fontFamily="@font/montserrat_medium"
                            android:gravity="center"
                            android:text="@string/add_address"
                            android:textColor="@color/white"
                            android:textSize="@dimen/text_fifteen" />
                    </LinearLayout>
                </LinearLayout>

            </ScrollView>


<!--            <View-->
