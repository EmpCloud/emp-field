<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.fragment.client.clientmap.ClinetMapShowFragment">

    <LinearLayout
        android:id="@+id/linearLayout2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_twenty"
        android:gravity="start"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.cardview.widget.CardView
            android:id="@+id/backbtnclient"
            android:layout_marginStart="@dimen/margin_twenty"
            android:layout_width="30dp"
            android:layout_height="30dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="15dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:padding="3dp"
                android:layout_gravity="center"
                android:src="@drawable/baseline_arrow_back_24" />
        </androidx.cardview.widget.CardView>
    </LinearLayout>


    <androidx.cardview.widget.CardView
        android:id="@+id/cardView3"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/margin_twenty"
        android:layout_marginBottom="@dimen/margin_hundred"
        app:cardCornerRadius="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout2"
        tools:layout_editor_absoluteX="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginBottom="30dp"
                android:orientation="vertical">

                <fragment
                    android:id="@+id/mapClient"
                    android:name="com.google.android.gms.maps.SupportMapFragment"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:nestedScrollingEnabled="true" />


                <ImageView
                    android:id="@+id/center_marker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:adjustViewBounds="true"
                    android:src="@drawable/marker_customs" />

                <!--                <EditText-->
                <!--                    android:layout_width="match_parent"-->
                <!--                    android:layout_height="40dp"-->
                <!--                    android:layout_marginStart="@dimen/margin_fifteen"-->
                <!--                    android:layout_marginEnd="@dimen/margin_fifteen"-->
                <!--                    android:layout_marginTop="@dimen/padding_twenty"-->
                <!--                    android:paddingStart="@dimen/padding_twenty"-->
                <!--                    android:paddingEnd="@dimen/padding_twenty"-->
                <!--                    android:drawablePadding="@dimen/padding_ten"-->
                <!--                    android:background="@drawable/map_search_background"-->
                <!--                    android:drawableStart="@drawable/search_icon"-->
                <!--                    android:hint="Search for area, street name..."-->
                <!--                    android:textSize="@dimen/text_twelve"-->
                <!--                    android:theme="@style/FontMedium"-->
                <!--                    android:textColor="@color/edit_text_hint_color"-->
                <!--                    />-->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <EditText
                        android:id="@+id/search_bar"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginStart="@dimen/margin_fifteen"
                        android:layout_marginTop="@dimen/padding_twenty"
                        android:layout_marginEnd="@dimen/margin_fifteen"
                        android:background="@drawable/map_search_background"
                        android:drawableStart="@drawable/baseline_search_24"
                        android:drawablePadding="@dimen/padding_ten"
                        android:hint="@string/search_for_area_street_name"
                        android:inputType="text"
                        android:maxLines="1"
                        android:paddingStart="@dimen/padding_twenty"
                        android:paddingEnd="@dimen/padding_twenty"
                        android:textColor="@color/black"
                        android:textColorHint="@color/new_edit_map_hint"
                        android:textSize="@dimen/text_twelve"
                        android:theme="@style/FontMedium" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/search_results"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone" />

                    <!--                    <fragment-->
                    <!--                        android:id="@+id/mapSearch"-->
                    <!--                        android:name="com.google.android.gms.maps.SupportMapFragment"-->
                    <!--                        android:layout_width="match_parent"-->
                    <!--                        android:layout_height="0dp"-->
                    <!--                        android:layout_weight="1" />-->
                </LinearLayout>


            </RelativeLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>


    <include
        android:id="@+id/bottomSheet"
        layout="@layout/bottom_sheet_map"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:behavior_hideable="true"
        app:behavior_peekHeight="74dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
    <LinearLayout
        android:id="@+id/currentlocbtn"
        android:clickable="true"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_alignParentBottom="true"
        android:layout_gravity="bottom"
        android:layout_marginStart="@dimen/user_heading_margin_eighty"
        android:layout_marginEnd="@dimen/user_heading_margin_eighty"
        android:background="@drawable/butoon_bg_shape"
        android:foreground="@drawable/ripple"
        android:gravity="center"
        android:orientation="horizontal"
        android:translationZ="10dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toTopOf="@id/bottomSheet">

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:src="@drawable/baseline_location_on_24" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="@string/use_current_location"
            android:textColor="@color/white"
            android:textSize="@dimen/text_twelve"
            android:textStyle="bold"
            android:theme="@style/FontMedium" />


    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>