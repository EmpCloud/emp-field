                    <!--                        android:textColor="@color/edit_text_black_color"-->
                    <!--                        android:textSize="12sp"-->
                    <!--                        android:theme="@style/FontMedium" />-->

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_twenty"
                        android:text="@string/category"
                        android:textColor="@color/user_form_text_color"
                        android:textSize="@dimen/text_fifteen"
                        android:textStyle="bold"
                        android:theme="@style/FontMedium" />


                    <EditText
                        android:id="@+id/category"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_ten"
                        android:background="@drawable/user_screen_edittext_bg"
                        android:hint="@string/enter_client_category"
                        android:inputType="text"
                        android:paddingStart="@dimen/padding_ten"
                        android:paddingTop="@dimen/padding_ten"
                        android:paddingBottom="@dimen/padding_ten"
                        android:textColor="@color/edit_text_black_color"
                        android:textSize="12sp"
                        android:theme="@style/FontMedium" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_twenty"
                        android:text="@string/address"
                        android:textColor="@color/user_form_text_color"
                        android:textSize="@dimen/text_fifteen"
                        android:textStyle="bold"
                        android:theme="@style/FontMedium" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="100dp"
                        android:layout_marginTop="@dimen/padding_ten"
                        android:background="@drawable/user_screen_edittext_bg"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/address"
                            android:focusable="false"
                            android:layout_width="match_parent"
                            android:layout_weight="1"
                            android:paddingEnd="@dimen/padding_ten"
                            android:layout_height="wrap_content"
                            android:layout_gravity="start"
                            android:background="@drawable/user_screen_edittext_bg"
                            android:gravity="start"
                            android:hint="@string/enter_address"
                            android:inputType="textMultiLine"
                            android:paddingStart="@dimen/padding_ten"
                            android:paddingTop="@dimen/padding_ten"
                            android:paddingBottom="@dimen/padding_ten"
                            android:textColor="@color/edit_text_black_color"
                            android:textSize="12sp"
                            android:theme="@style/FontMedium" />

                        <ImageView
                            android:id="@+id/editbtn"
                            android:clickable="true"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginEnd="@dimen/padding_ten"
                            android:src="@drawable/baseline_edit_24"/>

                    </LinearLayout>

                </LinearLayout>

            </ScrollView>

            <!--            DISABLE BUTOTN DESIGN-->

            <!--            <LinearLayout-->
            <!--                android:id="@+id/disable_client_btn"-->
