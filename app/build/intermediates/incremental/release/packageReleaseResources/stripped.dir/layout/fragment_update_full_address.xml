<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.fragment.update_address.UpdateFullAddressFragment">


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/linearLayout2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_twenty"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">


        <androidx.cardview.widget.CardView
            android:id="@+id/backbtn"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="@dimen/margin_twenty"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="15dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:padding="3dp"
                android:layout_gravity="center"
                android:src="@drawable/baseline_arrow_back_24" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/update_profile"
            android:textColor="@color/white"
            android:textSize="@dimen/text_sixteen"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <RelativeLayout
        android:id="@+id/relativeLayout"
        android:layout_width="115dp"
        android:layout_height="115dp"
        android:layout_marginTop="@dimen/margin_twenty"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout2">


        <androidx.cardview.widget.CardView
            android:layout_width="100dp"
            android:layout_height="100dp"
            app:cardCornerRadius="50dp"
            android:layout_centerInParent="true"
            android:background="@drawable/user_profile_background"
            android:gravity="center">

            <ImageView
                android:id="@+id/userPic"
                android:visibility="gone"
                android:layout_gravity="center"
                android:scaleType="centerCrop"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/icon_user_profile" />
            <ImageView
                android:id="@+id/userPicdisbale"
                android:visibility="visible"
                android:layout_gravity="center"
                android:layout_width="80dp"
                android:layout_height="match_parent"
                android:src="@drawable/userprofile_icon" />
        </androidx.cardview.widget.CardView>


        <!--        <LinearLayout-->
        <!--            android:id="@+id/camera"-->
        <!--            android:clickable="true"-->
        <!--            android:layout_width="40dp"-->
        <!--            android:layout_height="40dp"-->
        <!--            android:translationZ="2dp"-->
        <!--            android:layout_alignParentBottom="true"-->
        <!--            android:gravity="center"-->
        <!--            android:background="@drawable/user_image_upload_back"-->
        <!--            android:layout_alignParentEnd="true">-->
        <!--            <ImageView-->
        <!--                android:layout_width="wrap_content"-->
        <!--                android:layout_height="wrap_content"-->
        <!--                android:layout_gravity="center"-->
        <!--                android:src="@drawable/icon_camera"/>-->
        <!--        </LinearLayout>-->

    </RelativeLayout>

    <LinearLayout
        android:id="@+id/linearLayout20"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/margin_twenty"
        android:background="@drawable/client_bg"
        android:orientation="vertical"
        app:cardCornerRadius="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/relativeLayout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_twenty"
            android:layout_marginTop="@dimen/margin_twenty"
            android:layout_marginEnd="@dimen/margin_twenty"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/add_address"
                android:textColor="@color/user_form_text_color"
                android:textSize="@dimen/text_fifteen"
                android:textStyle="bold"
                android:theme="@style/FontMedium" />

            <EditText
                android:id="@+id/add_address_search"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="@dimen/margin_ten"
                android:background="@drawable/create_profile_address_back"
                android:clickable="true"
                android:drawableStart="@drawable/baseline_search_24"
                android:drawablePadding="@dimen/padding_ten"
                android:focusable="false"
                android:hint="@string/search_for_area_street_name"
                android:paddingStart="@dimen/padding_ten"
                android:paddingEnd="@dimen/padding_ten"
                android:textColor="@color/edit_text_hint_color"
                android:textSize="@dimen/text_twelve"
                android:theme="@style/FontMedium" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_ten"
                android:background="@drawable/create_profile_address_back"
                android:orientation="vertical"
                android:paddingBottom="@dimen/padding_twenty">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_ten"
                        android:layout_marginTop="@dimen/margin_ten"
                        android:layout_weight="1"
                        android:text="@string/enable_your_device_location"
                        android:textColor="@color/welcome_text_display_color"
                        android:textSize="@dimen/text_twelve"
                        android:theme="@style/FontMedium" />

                    <!-- Thumb color implementation code is
                    commented in the main activity class -->

                    <Switch
                        android:id="@+id/switchbtn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_ten"
                        android:layout_marginEnd="@dimen/margin_ten" />


                </LinearLayout>

                <View
                    android:id="@+id/view_firstName"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:layout_marginLeft="@dimen/margin_ten"
                    android:layout_marginTop="10dp"
                    android:layout_marginRight="@dimen/margin_ten"
                    android:background="@color/view_horizontal_line_color" />

                <LinearLayout
                    android:id="@+id/add_address_manually"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/margin_ten"
                    android:layout_marginBottom="@dimen/margin_twenty"
                    android:clickable="true"
                    android:foreground="@drawable/ripple"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginStart="@dimen/margin_ten"
                        android:text="+"
                        android:textColor="#2364B0"
                        android:textSize="@dimen/margin_fifteen"
                        android:theme="@style/FontMedium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginStart="@dimen/margin_ten"
                        android:text="@string/add_complete_address"
                        android:textColor="@color/welcome_text_display_color"
                        android:textSize="@dimen/text_twelve"
                        android:theme="@style/FontMedium" />
                </LinearLayout>

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_thirty"
                        android:layout_marginEnd="@dimen/margin_thirty"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/address_line_1"
                            android:textColor="@color/radio_button_text_color"
                            android:textSize="@dimen/text_twelve"
                            android:fontFamily="@font/montserrat_medium"/>

                        <EditText
                            android:id="@+id/addressfirst"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_five"
                            android:background="@drawable/white_edittext_back"
                            android:inputType="text"
                            android:paddingStart="@dimen/padding_ten"
                            android:paddingTop="@dimen/padding_ten"
                            android:paddingBottom="@dimen/padding_ten"
                            android:textColor="#5F5F5F"
                            android:textSize="12sp"
                            android:theme="@style/FontMedium" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_ten"
                            android:text="@string/address_line_2"
                            android:textColor="@color/radio_button_text_color"
                            android:textSize="@dimen/text_twelve"
                            android:fontFamily="@font/montserrat_medium"/>

                        <EditText
                            android:id="@+id/addressSecond"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_five"
                            android:background="@drawable/white_edittext_back"
                            android:inputType="text"
                            android:paddingStart="@dimen/padding_ten"
                            android:paddingTop="@dimen/padding_ten"
                            android:paddingBottom="@dimen/padding_ten"
                            android:textColor="#5F5F5F"
                            android:textSize="12sp"
                            android:theme="@style/FontMedium" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_ten"
                            android:text="@string/state"
                            android:textColor="@color/radio_button_text_color"
                            android:textSize="@dimen/text_twelve"
                            android:fontFamily="@font/montserrat_medium" />

                        <EditText
                            android:id="@+id/state"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_five"
                            android:background="@drawable/white_edittext_back"
                            android:inputType="text"
                            android:paddingStart="@dimen/padding_ten"
                            android:paddingTop="@dimen/padding_ten"
                            android:paddingBottom="@dimen/padding_ten"
                            android:textColor="#5F5F5F"
                            android:textSize="12sp"
                            android:theme="@style/FontMedium" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_ten"
                            android:text="@string/city"
                            android:textColor="@color/radio_button_text_color"
                            android:textSize="@dimen/text_twelve"
                            android:fontFamily="@font/montserrat_medium" />

                        <EditText
                            android:id="@+id/city"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_five"
                            android:background="@drawable/white_edittext_back"
                            android:inputType="text"
                            android:paddingStart="@dimen/padding_ten"
                            android:paddingTop="@dimen/padding_ten"
                            android:paddingBottom="@dimen/padding_ten"
                            android:textColor="#5F5F5F"
                            android:textSize="12sp"
                            android:theme="@style/FontMedium" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_ten"
                            android:text="@string/zip_code"
                            android:textColor="@color/radio_button_text_color"
                            android:textSize="@dimen/text_twelve"
                            android:fontFamily="@font/montserrat_medium"/>

                        <EditText
                            android:id="@+id/zip"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_five"
                            android:background="@drawable/white_edittext_back"
                            android:inputType="number"
                            android:paddingStart="@dimen/padding_ten"
                            android:paddingTop="@dimen/padding_ten"
                            android:paddingBottom="@dimen/padding_ten"
                            android:textColor="#5F5F5F"
                            android:textSize="12sp"
                            android:theme="@style/FontMedium" />

                    </LinearLayout>
                </ScrollView>
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/add_address_btn"
            android:layout_width="match_parent"
            android:layout_height="@dimen/user_screen_button_height"
            android:layout_gravity="bottom"
            android:layout_marginStart="@dimen/margin_twenty"
            android:layout_marginTop="@dimen/margin_twenty"
            android:layout_marginEnd="@dimen/margin_twenty"
            android:layout_marginBottom="@dimen/margin_twenty"
            android:background="@drawable/butoon_bg_shape"
            android:clickable="true"
            android:foreground="@drawable/ripple"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:text="@string/add_address"
                android:textColor="@color/white"
                android:textSize="@dimen/button_text_size"
                android:theme="@style/FontMedium" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/add_address_btndisable"
            android:layout_width="match_parent"
            android:layout_height="@dimen/user_screen_button_height"
            android:layout_marginStart="@dimen/margin_twenty"
            android:layout_marginTop="@dimen/margin_twenty"
            android:layout_marginEnd="@dimen/margin_twenty"
            android:layout_marginBottom="@dimen/margin_twenty"
            android:foreground="@drawable/ripple"
            android:background="@drawable/butoon_bg_shape_disabled"
            android:layout_gravity="bottom"
            android:clickable="true"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:theme="@style/FontMedium"
                android:gravity="center"
                android:text="@string/add_address"
                android:textColor="@color/white"
                android:textSize="@dimen/button_text_size" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>