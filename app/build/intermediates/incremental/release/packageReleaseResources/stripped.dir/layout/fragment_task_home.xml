            android:paddingTop="@dimen/margin_five"
            android:paddingEnd="@dimen/margin_five"
            android:translationZ="80dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <CheckBox
