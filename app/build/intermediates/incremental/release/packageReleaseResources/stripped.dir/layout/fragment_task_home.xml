        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerTask"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_ten"
            tools:listitem="@layout/task_listview_items" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:scaleType="center"
            android:adjustViewBounds="true"
            android:src="@drawable/tasksnothingfound"
            android:id="@+id/nothingfoundanimation"/>


    </LinearLayout>

    <LinearLayout
        android:id="@+id/addtbn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/margin_twenty"
        android:background="@drawable/floating_button_gradient_color_and_shape"
        android:elevation="2dp"
        android:foreground="@drawable/ripple_fab"
        android:translationZ="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="@dimen/padding_ten"
            android:src="@drawable/add_icon" />
    </LinearLayout>

    <include
