<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".ui.activity.welcom_tutorial.WelcomeActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:translationZ="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="@dimen/margin_hundred"
            android:textSize="@dimen/text_fourty_eight"
            android:textColor="@color/welcome_text_color"
            android:text="@string/welcome"/>

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/margin_twenty"
            android:src="@drawable/welcome_page_image"
            android:adjustViewBounds="true"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/margin_twenty"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/margin_twenty"
            android:paddingStart="@dimen/padding_twenty"
            android:paddingEnd="@dimen/padding_twenty"
            android:gravity="center"
            android:orientation="vertical">
<!--            <CheckBox-->
<!--                android:layout_width="wrap_content"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:gravity="center"-->
<!--                android:clickable="true"-->
<!--                android:layout_gravity="center"-->
<!--                android:layout_marginTop="@dimen/margin_twenty"-->
<!--                android:textSize="@dimen/text_fourteen"-->
<!--                android:id="@+id/termConditionCheckBox"-->
<!--                android:text="@string/accept_terms_amp_condition"-->
<!--                android:textStyle="bold"-->
<!--                android:fontFamily="@font/comfortaa_bold"-->
<!--                android:textColor="@color/terms_conditions_text_color"/>-->

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_ten"
                android:layout_marginTop="@dimen/margin_twenty"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/uncheckedterms"
                    android:clickable="true"
                    android:visibility="visible"
                    android:layout_width="wrap_content"
                    android:src="@drawable/rectangle_box_unchecked"
                    android:adjustViewBounds="true"
                    android:layout_gravity="center"
                    android:layout_height="wrap_content"/>

                <ImageView
                    android:id="@+id/checkedbterms"
                    android:visibility="gone"
                    android:background="@drawable/rectangle_checked_btn"
                    android:layout_width="wrap_content"
                    android:src="@drawable/baseline_check_24"
                    android:adjustViewBounds="true"
                    android:layout_gravity="center"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_ten"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="@string/accept_terms_amp_condition"
                    android:textStyle="bold"
                    android:fontFamily="@font/comfortaa_bold"
                    android:textColor="@color/terms_conditions_text_color" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:theme="@style/FontMedium"
                    android:textSize="@dimen/text_fourteen"
                    android:textColor="@color/welcome_text_display_color"
                    android:text="@string/welcome_display_text" />

                <TextView
                    android:id="@+id/termsconditions"
                    android:clickable="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:theme="@style/FontMedium"
                    android:textSize="@dimen/text_fourteen"
                    android:textColor="@color/buttonbgcolor"
                    android:text="@string/terms_amp_conditions" />
            </LinearLayout>


        </LinearLayout>
    </LinearLayout>
    <ImageView
        android:id="@+id/imageView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        android:src="@drawable/screen_bottom_image"
        app:layout_constraintBottom_toBottomOf="parent" />

    <LinearLayout
        android:visibility="gone"
        android:id="@+id/webviewlayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:translationZ="20dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:background="@color/buttonbgcolor">

            <ImageView
                android:id="@+id/backbtn"
                android:layout_marginStart="@dimen/margin_twenty"
                android:clickable="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/arrow_back"
                android:layout_gravity="center"
                app:tint="@color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/accept_terms_amp_condition"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:layout_gravity="center"
                android:theme="@style/FontMedium"
                android:layout_marginStart="@dimen/margin_twenty"/>

        </LinearLayout>

        <WebView
            android:id="@+id/webview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:translationZ="20dp"/>
    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>