<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@drawable/profile_background"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/constraintLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/margin_fifteen"
        android:layout_marginEnd="@dimen/margin_fifteen"
        android:layout_marginTop="@dimen/margin_twenty"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        tools:layout_editor_absoluteX="15dp">

        <!--        back arrow view-->

        <ImageView
            android:id="@+id/imageView4"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:background="@drawable/icon_white_circular_back"
            android:padding="@dimen/padding_ten"
            android:src="@drawable/arrow_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <!--        user profile linear-->

        <ImageView
            android:id="@+id/imageView5"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="start"
            android:layout_marginStart="@dimen/margin_fifteen"
            android:background="@drawable/icon_white_circular_back"
            android:padding="@dimen/padding_ten"
            android:src="@drawable/icon_profile"
            app:layout_constraintStart_toEndOf="@+id/imageView4"
            app:layout_constraintTop_toTopOf="parent" />


        <TextView
            android:id="@+id/textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="Tasks"
            android:textColor="@color/white"
            android:textSize="@dimen/text_twenty"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <!--        notificaiton icon linear-->

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:background="@drawable/icon_white_circular_back"
            android:padding="@dimen/padding_ten"
            android:src="@drawable/icon_notify"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/linearLayout9"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/margin_twenty"
        android:background="@drawable/white_back_user_profile_shape"
        android:elevation="10dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/constraintLayout">


        <LinearLayout
            android:id="@+id/linearLayout12"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_fifteen"
            android:layout_marginEnd="@dimen/margin_fifteen"
            android:orientation="vertical"
            app:layout_constraintTop_toTopOf="parent"
            tools:layout_editor_absoluteX="20dp">


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/margin_twenty"
                android:gravity="center"
                android:text="Task"
                android:textColor="@color/black_text_color"
                android:textSize="@dimen/text_eighteen" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_twenty"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/profile_view_icon"/>


                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_twenty"
                    android:layout_gravity="center"
                    android:text="Aman Singh"
                    android:theme="@style/FontMedium"
                    android:textColor="@color/welcome_text_display_color"
                    android:textSize="@dimen/text_fourteen" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_twenty"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/time_icon"/>


                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_twenty"
                    android:layout_gravity="center"
                    android:text="10:00AM-11:00AM"
                    android:textColor="@color/blue_list_title"
                    android:textSize="@dimen/text_fourteen" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_twenty"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/live_location_icon"/>


                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_twenty"
                    android:layout_gravity="center"
                    android:text="House no. 123, Bengaluru"
                    android:theme="@style/FontMedium"
                    android:textColor="@color/welcome_text_display_color"
                    android:textSize="@dimen/text_fourteen" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_thirty"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Pick up"
                    android:textColor="@color/welcome_text_display_color"
                    android:textSize="@dimen/text_fourteen" />


                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_ten"
                    android:background="@drawable/finish_edit_text_shape"
                    android:hint="Rs 4059 "
                    android:inputType="text"
                    android:theme="@style/FontMedium"
                    android:paddingTop="@dimen/margin_fifteen"
                    android:paddingBottom="@dimen/margin_fifteen"
                    android:paddingStart="@dimen/padding_ten"
                    android:paddingEnd="@dimen/padding_ten"
                    android:textSize="@dimen/text_fourteen"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_twenty"
                    android:layout_gravity="center"
                    android:text="Picutre"
                    android:textColor="@color/welcome_text_display_color"
                    android:textSize="@dimen/text_fourteen" />


                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_ten"
                    android:background="@drawable/finish_edit_text_shape"
                    android:hint="Insurance document "
                    android:inputType="text"
                    android:theme="@style/FontMedium"
                    android:paddingTop="@dimen/margin_fifteen"
                    android:paddingBottom="@dimen/margin_fifteen"
                    android:paddingStart="@dimen/padding_ten"
                    android:paddingEnd="@dimen/padding_ten"
                    android:textSize="@dimen/text_fourteen"/>

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:adjustViewBounds="true"
                    android:layout_marginTop="@dimen/margin_five"
                    android:background="@drawable/capture_circular_back"
                    android:padding="@dimen/padding_ten"
                    android:src="@drawable/capture_icon" />




            </LinearLayout>




        </LinearLayout>


        <LinearLayout
            android:id="@+id/linearLayout14"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_fifteen"
            android:layout_marginEnd="@dimen/margin_fifteen"
            android:layout_marginBottom="@dimen/margin_thirty"
            android:orientation="horizontal"
            app:layout_constraintBottom_toTopOf="@+id/linearLayout13"
            tools:layout_editor_absoluteX="10dp">

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="2dp"
                android:layout_marginTop="@dimen/margin_five"
                android:layout_marginEnd="@dimen/margin_five"
                android:layout_marginBottom="@dimen/margin_five"
                android:layout_weight="1"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:background="@drawable/linear_card_back"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="@dimen/padding_ten"
                    android:paddingBottom="@dimen/padding_ten">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:adjustViewBounds="true"
                        android:background="@drawable/task_circular_back"
                        android:padding="@dimen/padding_ten"
                        android:src="@drawable/reschedule_icon" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="@dimen/margin_five"
                        android:gravity="center"
                        android:text="Reschedule"
                        android:textColor="@color/welcome_text_display_color"
                        android:textSize="@dimen/text_twelve" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="2dp"
                android:layout_marginTop="@dimen/margin_five"
                android:layout_marginEnd="2dp"
                android:layout_marginBottom="@dimen/margin_five"
                android:layout_weight="1"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:background="@drawable/linear_card_back"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="@dimen/padding_ten"
                    android:paddingBottom="@dimen/padding_ten">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:adjustViewBounds="true"
                        android:background="@drawable/capture_circular_back"
                        android:padding="@dimen/padding_ten"
                        android:src="@drawable/capture_icon" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="@dimen/margin_five"
                        android:gravity="center"
                        android:text="Add Picture"
                        android:textColor="@color/welcome_text_display_color"
                        android:textSize="@dimen/text_twelve" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="5dp"
                android:layout_marginTop="@dimen/margin_five"
                android:layout_marginEnd="2dp"
                android:layout_marginBottom="@dimen/margin_five"
                android:layout_weight="1"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:background="@drawable/linear_card_back"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="@dimen/padding_ten"
                    android:paddingBottom="@dimen/padding_ten">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:adjustViewBounds="true"
                        android:background="@drawable/form_circular_back"
                        android:padding="@dimen/padding_ten"
                        android:src="@drawable/activity_icon" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="@dimen/margin_five"
                        android:gravity="center"
                        android:text="Add Form"
                        android:textColor="@color/welcome_text_display_color"
                        android:textSize="@dimen/text_twelve" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>


        </LinearLayout>

        <LinearLayout
            android:id="@+id/linearLayout13"
            android:layout_width="match_parent"
            android:layout_height="@dimen/user_screen_button_height"
            android:layout_margin="@dimen/margin_twenty"
            android:background="@drawable/butoon_bg_shape"
            android:clickable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="@+id/linearLayout9"
            tools:layout_editor_absoluteX="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:text="Finish"
                android:textColor="@color/white"
                android:textSize="@dimen/button_text_size"
                android:theme="@style/FontMedium" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.constraintlayout.widget.ConstraintLayout>