<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@drawable/profile_background"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/constraintLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/margin_fifteen"
        android:layout_marginEnd="@dimen/margin_fifteen"
        android:layout_marginTop="@dimen/margin_twenty"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        tools:layout_editor_absoluteX="15dp">

        <!--        back arrow view-->

        <ImageView
            android:id="@+id/imageView4"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:background="@drawable/icon_white_circular_back"
            android:padding="@dimen/padding_ten"
            android:src="@drawable/arrow_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <!--        user profile linear-->

        <ImageView
            android:id="@+id/imageView5"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="start"
            android:layout_marginStart="@dimen/margin_fifteen"
            android:background="@drawable/icon_white_circular_back"
            android:padding="@dimen/padding_ten"
            android:src="@drawable/icon_profile"
            app:layout_constraintStart_toEndOf="@+id/imageView4"
            app:layout_constraintTop_toTopOf="parent" />


        <TextView
            android:id="@+id/textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="Tasks"
            android:textColor="@color/white"
            android:textSize="@dimen/text_twenty"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <!--        notificaiton icon linear-->

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:background="@drawable/icon_white_circular_back"
            android:padding="@dimen/padding_ten"
            android:src="@drawable/icon_notify"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/linearLayout8"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/margin_twenty"
        android:background="@drawable/profile_back_shape"
        android:elevation="10dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/constraintLayout">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/linearLayout10"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="@dimen/margin_twenty"
                android:layout_marginEnd="@dimen/margin_fifty"
                android:layout_marginStart="@dimen/margin_fifty"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/blue_shape_color"
                    android:drawableStart="@drawable/task_search_icon"
                    android:drawablePadding="@dimen/padding_ten"
                    android:hint="Search..."
                    android:paddingStart="@dimen/padding_ten"
                    android:paddingTop="@dimen/padding_ten"
                    android:paddingEnd="@dimen/padding_twenty"
                    android:paddingBottom="@dimen/padding_ten"
                    android:textColor="@color/white"
                    android:textColorHint="@color/white"
                    android:textSize="@dimen/text_twelve"
                    android:theme="@style/FontMedium" />

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_margin="@dimen/margin_twenty"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/linearLayout10"
                tools:layout_editor_absoluteX="15dp"
                tools:listitem="@layout/task_listitems_screen" />


            <!--        THIS IS DISABLED BUTTON DESIGN -->
            <LinearLayout
                android:id="@+id/linearLayout11"
                android:layout_width="match_parent"
                android:layout_height="@dimen/user_screen_button_height"
                android:layout_gravity="bottom"
                android:layout_margin="@dimen/margin_twenty"
                android:background="@drawable/butoon_bg_shape_disabled"
                android:clickable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:translationZ="10dp"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="Submit"
                    android:textColor="@color/white"
                    android:textSize="@dimen/button_text_size"
                    android:theme="@style/FontMedium" />
            </LinearLayout>

            <!--        THIS IS ACTIVE BUTTON DESIGN WHERE VISIBILITY SET TO GONE USE ACCORDINGLY LOGIC-->

            <LinearLayout
                android:visibility="visible"
                android:layout_width="match_parent"
                android:layout_height="@dimen/user_screen_button_height"
                android:layout_gravity="bottom"
                android:layout_marginBottom="@dimen/margin_thirty"
                android:translationZ="10dp"
                android:background="@drawable/butoon_bg_shape"
                android:clickable="true"
                android:gravity="center"
                android:layout_margin="@dimen/margin_twenty"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="Select Client"
                    android:textColor="@color/white"
                    android:textSize="@dimen/button_text_size"
                    android:theme="@style/FontMedium" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>


    </LinearLayout>









</androidx.constraintlayout.widget.ConstraintLayout>