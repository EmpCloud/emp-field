<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">


    <LinearLayout
        android:id="@+id/linearLayout6"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@color/white"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingTop="@dimen/padding_ten"
        android:paddingBottom="@dimen/padding_ten"
        app:layout_constraintTop_toTopOf="parent"
        tools:layout_editor_absoluteX="5dp">

        <TextView
            android:id="@+id/holidayTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:theme="@style/monstreat_semibold"
            android:layout_marginStart="@dimen/margin_thirty"
            android:layout_weight="1"
            android:gravity="start"
            android:text="New Year"
            android:fontFamily="@font/montserrat_bold"
            android:textColor="@color/holidays_listitems_color1"
            android:textSize="@dimen/text_fourteen" />

        <TextView
            android:id="@+id/holidayDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:layout_weight="2"
            android:gravity="start"
            android:text="01-01-2023"
            android:fontFamily="@font/montserrat_medium"
            android:textColor="@color/welcome_text_display_color"
            android:textSize="@dimen/text_fourteen"
            android:theme="@style/FontMedium" />

        <!-- Textview for blue text where visibilit set to gone use this by providing id
        and in logic change visibility-->

        <TextView
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:layout_weight="2"
            android:gravity="start"
            android:text="01-01-2023"
            android:textColor="@color/welcome_text_color"
            android:textSize="@dimen/text_fourteen"
            android:theme="@style/FontMedium" />


    </LinearLayout>

    <View
        android:id="@+id/viewdivider"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/weekoff"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout6"
        tools:layout_editor_absoluteX="0dp" />

</androidx.constraintlayout.widget.ConstraintLayout>