<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:translationZ="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="@dimen/margin_hundred"
            android:textSize="@dimen/text_fourty_eight"
            android:textColor="@color/welcome_text_color"
            android:text="Welcome!"/>

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/welcome_page_image"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/margin_twenty"/>

      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_gravity="center"
          android:layout_marginTop="@dimen/margin_twenty"
          android:paddingStart="@dimen/padding_twenty"
          android:paddingEnd="@dimen/padding_twenty"
          android:gravity="center"
          android:orientation="vertical">
          <CheckBox
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:layout_gravity="start"
              android:layout_marginTop="@dimen/margin_twenty"
              android:layout_marginStart="@dimen/margin_twenty"
              android:textSize="@dimen/text_fourteen"
              android:id="@+id/termConditionCheckBox"
              android:text="Accept Terms &amp; Condition"
              android:textStyle="bold"
              android:fontFamily="@font/comfortaa_bold"
              android:textColor="@color/terms_conditions_text_color"/>

          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:gravity="center"
              android:fontFamily="@font/montserrat_medium"
              android:textSize="@dimen/text_fourteen"
              android:textColor="@color/welcome_text_display_color"
              android:text="@string/welcome_display_text" />

      </LinearLayout>
    </LinearLayout>


    <ImageView
        android:id="@+id/imageView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        android:src="@drawable/screen_bottom_image"
        app:layout_constraintBottom_toBottomOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>