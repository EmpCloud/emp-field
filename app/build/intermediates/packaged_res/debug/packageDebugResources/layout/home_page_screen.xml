<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@drawable/profile_background"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/linearLayout3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/margin_twenty"
        android:layout_marginEnd="@dimen/margin_twenty"
        android:layout_marginTop="@dimen/margin_twenty"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        tools:layout_editor_absoluteX="20dp">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:gravity="start">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:background="@drawable/icon_white_circular_back"
                    android:padding="@dimen/padding_ten"
                    android:src="@drawable/icon_profile" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginStart="@dimen/margin_twenty"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Hi!"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_twenty_four"
                    android:theme="@style/FontBold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:gravity="end"
                    android:text="Aman Singh"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_twenty"
                    android:theme="@style/FontBold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Android Developer"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_twelve"
                    android:theme="@style/FontMedium" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_weight="1"
            android:gravity="end">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:background="@drawable/icon_white_circular_back"
                android:padding="@dimen/padding_ten"
                android:src="@drawable/icon_notify" />
        </LinearLayout>

    </LinearLayout>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:layout_marginTop="10dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavigationView"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout3">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="@dimen/padding_ten"
            android:background="@drawable/edit_text_back"
            android:orientation="vertical"
            android:translationZ="10dp"
            android:id="@+id/swipeArea"
            android:layout_marginEnd="@dimen/margin_twenty"
            android:layout_marginStart="@dimen/margin_twenty"
            android:paddingStart="@dimen/padding_twenty"
            android:paddingEnd="@dimen/padding_twenty">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_ten"
                    android:layout_weight="1"
                    android:text="Wed, Oct 04"
                    android:textColor="@color/black_text_color"
                    android:textSize="@dimen/button_text_size"
                    android:textStyle="bold"
                    android:theme="@style/FontMedium" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_ten"
                    android:layout_weight="1"
                    android:gravity="end">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/time_shower_shape"
                        android:paddingStart="@dimen/padding_ten"
                        android:paddingTop="5dp"
                        android:paddingEnd="@dimen/padding_ten"
                        android:paddingBottom="5dp"
                        android:text="00:05"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text_fourteen"
                        android:theme="@style/FontMedium" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/margin_ten"
                android:gravity="center"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="start"
                        android:text="Check IN"
                        android:textColor="@color/buttonbgcolor"
                        android:textSize="@dimen/text_sixteen"
                        android:theme="@style/UbuntuRegular" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_medium"
                            android:gravity="start"
                            android:text="09:55"
                            android:textColor="@color/time_display_color"
                            android:textSize="@dimen/text_twenty"
                            android:theme="@style/FontMedium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_medium"
                            android:gravity="start"
                            android:text="am"
                            android:textColor="@color/time_display_color"
                            android:textSize="@dimen/text_twelve"
                            android:theme="@style/FontMedium" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:text="Check OUT"
                        android:textColor="@color/buttonbgcolor"
                        android:textSize="@dimen/text_sixteen"
                        android:theme="@style/UbuntuRegular" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:gravity="end"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_medium"
                            android:gravity="end"
                            android:text="00:00"
                            android:textColor="@color/time_display_color"
                            android:textSize="@dimen/text_twenty"
                            android:theme="@style/FontMedium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_medium"
                            android:gravity="start"
                            android:text="pm"
                            android:textColor="@color/time_display_color"
                            android:textSize="@dimen/text_twelve"
                            android:theme="@style/FontMedium" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>


            <!--        HERE YOU HAVE TO CODE FOR THE SEEKBAR THE BELOW CODE IS JUST DUMMY CODE TO
             SHOW HERE SEEKBAR IS USED
             -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:gravity="center">

                <SeekBar
                    android:id="@+id/seekbar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:indeterminate="false"
                    android:max="50"
                    android:progress="0"
                    android:progressDrawable="@drawable/custom_seekbar_user_profile"
                    android:thumb="@drawable/seekbar_thum_shaape" />

            </LinearLayout>

        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@+id/swipeArea"
            android:translationZ="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_twenty"
                android:layout_marginStart="@dimen/margin_twenty"
                android:layout_marginEnd="@dimen/margin_twenty"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Yesterday’s Record "
                    android:textStyle="bold"
                    android:theme="@style/FontMedium"
                    android:textColor="@color/black_text_color"
                    android:textSize="@dimen/text_eighteen"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_twenty"
                    android:orientation="vertical"
                    android:background="@drawable/edit_text_back">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_twenty"
                        android:layout_marginTop="@dimen/margin_ten"
                        android:text="Tue, Oct 03"
                        android:textSize="@dimen/text_fifteen"
                        android:theme="@style/FontMedium"
                        android:textColor="@color/bottom_icon_color"
                        />

                    <LinearLayout
                        android:id="@+id/linearLayout2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_ten"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingBottom="@dimen/padding_twenty"
                        android:paddingStart="@dimen/padding_ten"
                        android:paddingEnd="@dimen/padding_ten">


                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <androidx.cardview.widget.CardView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_margin="5dp"
                                app:cardCornerRadius="15dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:layout_gravity="center"
                                    android:padding="@dimen/padding_ten"
                                    android:background="@drawable/records_common_back_shape"
                                    android:gravity="center"
                                    android:orientation="vertical">

                                    <ImageView
                                        android:layout_width="50dp"
                                        android:layout_height="50dp"
                                        android:adjustViewBounds="true"
                                        android:src="@drawable/distance_travelled_icon" />

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="center"
                                        android:layout_marginTop="@dimen/margin_twenty"
                                        android:theme="@style/FontBold"
                                        android:textSize="@dimen/text_fourteen"
                                        android:gravity="center"
                                        android:text="0.0 KM"
                                        android:textColor="@color/records_card_text_color" />
                                </LinearLayout>
                            </androidx.cardview.widget.CardView>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:theme="@style/FontMedium"
                                android:textSize="@dimen/text_twelve"
                                android:gravity="center"
                                android:text="Distance \nTravelled"
                                android:textColor="@color/records_card_text_color" />

                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <androidx.cardview.widget.CardView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_margin="5dp"
                                app:cardCornerRadius="15dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:layout_gravity="center"
                                    android:padding="@dimen/padding_ten"
                                    android:background="@drawable/records_common_back_shape"
                                    android:gravity="center"
                                    android:orientation="vertical">

                                    <ImageView
                                        android:layout_width="50dp"
                                        android:layout_height="50dp"
                                        android:adjustViewBounds="true"
                                        android:src="@drawable/time_clock_icon" />

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="center"
                                        android:layout_marginTop="@dimen/margin_twenty"
                                        android:theme="@style/FontBold"
                                        android:textSize="@dimen/text_fourteen"
                                        android:gravity="center"
                                        android:text="09:11:02"
                                        android:textColor="@color/records_card_text_color" />
                                </LinearLayout>
                            </androidx.cardview.widget.CardView>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:theme="@style/FontMedium"
                                android:textSize="@dimen/text_twelve"
                                android:gravity="center"
                                android:text="Hrs\nworked"
                                android:textColor="@color/records_card_text_color" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <androidx.cardview.widget.CardView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_margin="5dp"
                                app:cardCornerRadius="15dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:layout_gravity="center"
                                    android:padding="@dimen/padding_ten"
                                    android:background="@drawable/records_common_back_shape"
                                    android:gravity="center"
                                    android:orientation="vertical">

                                    <ImageView
                                        android:layout_width="50dp"
                                        android:layout_height="50dp"
                                        android:adjustViewBounds="true"
                                        android:src="@drawable/task_complete_icon" />

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="center"
                                        android:layout_marginTop="@dimen/margin_twenty"
                                        android:theme="@style/FontBold"
                                        android:textSize="@dimen/text_fourteen"
                                        android:gravity="center"
                                        android:text="5/5"
                                        android:textColor="@color/records_card_text_color" />
                                </LinearLayout>
                            </androidx.cardview.widget.CardView>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:theme="@style/FontMedium"
                                android:textSize="@dimen/text_twelve"
                                android:gravity="center"
                                android:text="Task\nCompleted"
                                android:textColor="@color/records_card_text_color" />

                        </LinearLayout>


                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_twenty"
                android:layout_marginEnd="@dimen/margin_twenty"
                android:layout_marginTop="@dimen/margin_twenty"
                android:gravity="center"
                android:orientation="horizontal">


                <androidx.cardview.widget.CardView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_margin="5dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="15dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        android:padding="@dimen/padding_ten"
                        android:background="@drawable/home_page_attendance_back_shape"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:layout_marginTop="@dimen/margin_ten"
                            android:adjustViewBounds="true"
                            android:padding="@dimen/padding_ten"
                            android:background="@drawable/user_profile_background"
                            android:layout_gravity="center"
                            android:src="@drawable/attend_ic" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginTop="@dimen/margin_ten"
                            android:theme="@style/FontBold"
                            android:textSize="@dimen/text_fourteen"
                            android:gravity="center"
                            android:text="Attendance History"
                            android:textColor="@color/white" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_margin="5dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="15dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="@dimen/padding_ten"
                        android:layout_gravity="center"
                        android:background="@drawable/home_page_leaves_shape_back"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:adjustViewBounds="true"
                            android:layout_gravity="center"
                            android:padding="@dimen/padding_ten"
                            android:background="@drawable/user_profile_background"
                            android:src="@drawable/leaves_ic" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginTop="@dimen/margin_ten"
                            android:gravity="center"
                            android:text="Leaves"
                            android:textColor="@color/white" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_margin="5dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="15dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        android:padding="@dimen/padding_ten"
                        android:background="@drawable/home_page_holidays_shape_back"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:adjustViewBounds="true"
                            android:padding="@dimen/padding_ten"
                            android:layout_gravity="center"
                            android:background="@drawable/user_profile_background"
                            android:src="@drawable/holiday_ic" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginTop="@dimen/margin_ten"
                            android:gravity="center"
                            android:text="Holidays"
                            android:textColor="@color/white" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </LinearLayout>

        </ScrollView>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="50dp"
            android:background="@drawable/profile_back_shape"
            android:orientation="vertical"/>
    </RelativeLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="match_parent"
        app:labelVisibilityMode="labeled"
        android:layout_height="65dp"
        app:itemIconTint="@color/bottom_icon_color"
        android:background="@color/white"
        app:itemTextColor="@color/bottom_icon_color"
        android:theme="@style/UbuntuMedium"
        android:layout_alignParentBottom="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_navigation_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>