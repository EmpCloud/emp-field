                        android:id="@+id/autoCompleteLeave"
                        android:layout_width="match_parent"
                        android:layout_marginTop="@dimen/margin_five"
                        android:layout_height="40dp"
                        android:background="@drawable/add_lv_et_bg"/>
            </LinearLayout>


        </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_twenty"
                android:layout_marginEnd="@dimen/margin_twenty"
                android:layout_marginTop="@dimen/margin_ten"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/margin_ten"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/start_date"
                        android:fontFamily="@font/montserrat_semibold"
                        android:textColor="@color/new_txt_3a"
                        android:textSize="@dimen/text_twelve"
                        />

                    <EditText
                        android:id="@+id/startDate"
                        android:layout_width="match_parent"
                        android:focusable="false"
                        android:layout_height="40dp"
                        android:layout_marginTop="@dimen/margin_five"
                        android:paddingStart="@dimen/padding_ten"
                        android:paddingEnd="@dimen/padding_ten"
                        android:drawablePadding="@dimen/padding_ten"
                        android:background="@drawable/add_lv_et_bg"
                        android:hint="yyyy--mm-dd"
                        android:textSize="@dimen/text_twelve"
                        android:fontFamily="@font/montserrat_medium"
                        android:textColor="@color/holidays_listitems_color1"
                        />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_ten"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/end_date"
                        android:fontFamily="@font/montserrat_semibold"
                        android:textColor="@color/new_txt_3a"
                        android:textSize="@dimen/text_twelve"
                        />


                    <EditText
                        android:id="@+id/endDate"
                        android:focusable="false"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="@dimen/margin_five"
                        android:paddingStart="@dimen/padding_ten"
                        android:paddingEnd="@dimen/padding_ten"
                        android:drawablePadding="@dimen/padding_ten"
                        android:background="@drawable/add_lv_et_bg"
                        android:hint="yyyy--mm-dd"
                        android:textSize="@dimen/text_twelve"
                        android:fontFamily="@font/montserrat_medium"
                        android:textColor="@color/holidays_listitems_color1"
                        />

                </LinearLayout>


            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_twenty"
                android:layout_marginEnd="@dimen/margin_twenty"
                android:layout_marginTop="@dimen/margin_ten"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/reason"
                    android:fontFamily="@font/montserrat_semibold"
                    android:textColor="@color/new_txt_3a"
                    android:textSize="@dimen/text_twelve"
                    />


                <EditText
                    android:id="@+id/reason"
                    android:layout_width="match_parent"
                    android:inputType="text"
                    android:layout_height="80dp"
                    android:layout_gravity="start"
                    android:gravity="start"
                    android:paddingTop="@dimen/padding_ten"
                    android:paddingStart="@dimen/padding_ten"
                    android:paddingEnd="@dimen/padding_ten"
                    android:layout_marginTop="@dimen/margin_five"
                    android:background="@drawable/add_lv_et_bg"
                    android:hint="@string/write_reason_here"
                    android:textSize="@dimen/text_twelve"
                    android:fontFamily="@font/montserrat_medium"
                    android:textColor="@color/holidays_listitems_color1"
                    />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/nextbtn"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_marginTop="@dimen/margin_twenty"
                android:layout_height="@dimen/user_screen_button_height"
                android:layout_marginStart="@dimen/margin_twenty"
                android:layout_marginEnd="@dimen/margin_twenty"
                android:layout_marginBottom="@dimen/margin_twenty"
                android:foreground="@drawable/ripple"
                android:background="@drawable/butoon_bg_shape"
                android:layout_gravity="bottom"
                android:clickable="true"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:theme="@style/FontMedium"
                    android:gravity="center"
                    android:text="@string/apply"
                    android:textColor="@color/white"
                    android:textSize="@dimen/button_text_size" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nextbtndisable"
                android:visibility="visible"
                android:layout_width="match_parent"
                android:layout_marginTop="@dimen/margin_twenty"
                android:layout_height="@dimen/user_screen_button_height"
                android:layout_marginStart="@dimen/margin_twenty"
                android:layout_marginEnd="@dimen/margin_twenty"
                android:layout_marginBottom="@dimen/margin_twenty"
                android:background="@drawable/butoon_bg_shape_disabled"
                android:layout_gravity="bottom"
                android:clickable="true"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:theme="@style/FontMedium"
                    android:gravity="center"
                    android:text="@string/apply"
                    android:textColor="@color/white"
                    android:textSize="@dimen/button_text_size" />
            </LinearLayout>

