<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:background="@color/white"
    android:translationZ="10dp"
    android:paddingBottom="@dimen/margin_thirty"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="@dimen/padding_ten"
        android:paddingBottom="@dimen/padding_ten"
        android:layout_marginStart="@dimen/margin_fifteen"
        android:layout_marginEnd="@dimen/margin_fifteen"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        tools:layout_editor_absoluteX="15dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/edit_text_back"
            android:orientation="horizontal">


            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:background="@drawable/gradient_circular_back_shap"
                android:padding="@dimen/padding_ten"
                android:src="@drawable/icon_user_profile"
                app:tint="@color/white" />


            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginStart="@dimen/margin_twenty"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="start"
                    android:text="Aman Singh"
                    android:textColor="@color/grey_text_color"
                    android:textSize="@dimen/text_fifteen" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginTop="@dimen/margin_five"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginEnd="@dimen/margin_five"
                        android:layout_gravity="center"
                        android:background="@drawable/home_page_holidays_shape_back"
                        android:padding="@dimen/margin_five"
                        android:src="@drawable/baseline_location_on_24"
                        android:visibility="visible" />

                    <TextView
                        android:id="@+id/address"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="start"
                        android:text="devansh@gmail.com"
                        android:textColor="@color/grey_text_color"
                        android:textSize="@dimen/text_twelve"
                        android:theme="@style/FontMedium" />

                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_twenty"
            android:orientation="horizontal">

<!--            FOR THE CALL LIGHT BACKGROUND DESIGN-->

                <LinearLayout
                    android:id="@+id/Call"
                    android:clickable="true"
                    android:elevation="@dimen/margin_five"
                    android:layout_margin="@dimen/margin_five"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/margin_five"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:paddingTop="@dimen/padding_ten"
                    android:paddingBottom="@dimen/padding_ten"
                    android:background="@drawable/direction_bg"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:adjustViewBounds="true"
                        android:padding="@dimen/padding_ten"
                        android:background="@drawable/white_circular_shape_for_card"
                        android:layout_gravity="center"
                        android:src="@drawable/phone_icon" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="@dimen/margin_five"
                        android:textSize="@dimen/text_twelve"
                        android:gravity="center"
                        android:text="@string/call"
                        android:textColor="@color/welcome_text_display_color" />
                </LinearLayout>

<!--            DARK DESIGN OF CALL BUTTON-->

            <LinearLayout
                android:id="@+id/selectCall"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/margin_five"
                android:layout_gravity="center"
                android:layout_weight="1"
                android:paddingTop="@dimen/padding_ten"
                android:paddingBottom="@dimen/padding_ten"
                android:background="@drawable/client_sceen_3_box"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:adjustViewBounds="true"
                    android:padding="@dimen/padding_ten"
                    android:background="@drawable/white_circular_shape_for_card"
                    android:layout_gravity="center"
                    android:src="@drawable/phone_icon" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/margin_five"
                    android:textSize="@dimen/text_twelve"
                    android:gravity="center"
                    android:text="Call"
                    android:textColor="@color/white" />
            </LinearLayout>


<!--            MESSGAGE LIGHT BACKGROUND BUTTON-->
            <LinearLayout
                     android:id="@+id/message"
                    android:clickable="true"
                android:elevation="@dimen/margin_five"
                android:layout_margin="@dimen/margin_five"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_five"
                    android:layout_marginEnd="@dimen/margin_five"
                    android:layout_weight="1"
                    android:paddingTop="@dimen/padding_ten"
                    android:paddingBottom="@dimen/padding_ten"
                    android:layout_gravity="center"
                    android:background="@drawable/direction_bg"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:adjustViewBounds="true"
                        android:padding="@dimen/padding_ten"
                        android:background="@drawable/white_circular_shape_for_card"
                        android:layout_gravity="center"
                        android:src="@drawable/message_icon" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="@dimen/margin_five"
                        android:textSize="@dimen/text_twelve"
                        android:gravity="center"
                        android:text="@string/message"
                        android:textColor="@color/welcome_text_display_color" />
                </LinearLayout>


<!--            DARK BACKGROUND BUTTON FOR MESSAGE-->
            <LinearLayout
                android:id="@+id/selectMessage"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/margin_five"
                android:layout_gravity="center"
                android:layout_weight="1"
                android:paddingTop="@dimen/padding_ten"
                android:paddingBottom="@dimen/padding_ten"
                android:background="@drawable/client_sceen_3_box"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:adjustViewBounds="true"
                    android:padding="@dimen/padding_ten"
                    android:background="@drawable/white_circular_shape_for_card"
                    android:layout_gravity="center"
                    android:src="@drawable/message_icon" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/margin_five"
                    android:textSize="@dimen/text_twelve"
                    android:gravity="center"
                    android:text="Message"
                    android:textColor="@color/white" />
            </LinearLayout>

<!--    LIGHT BACKGROUND FOR DIRECTION-->
            <LinearLayout
                    android:id="@+id/direction"
                     android:clickable="true"
                android:elevation="@dimen/margin_five"
                android:layout_margin="@dimen/margin_five"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_five"
                    android:layout_weight="1"
                    android:paddingTop="@dimen/padding_ten"
                    android:paddingBottom="@dimen/padding_ten"
                    android:layout_gravity="center"
                     android:background="@drawable/direction_bg"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:adjustViewBounds="true"
                        android:padding="@dimen/padding_ten"
                        android:background="@drawable/white_circular_shape_for_card"
                        android:layout_gravity="center"
                        android:src="@drawable/direction_icon" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="@dimen/margin_five"
                        android:textSize="@dimen/text_twelve"
                        android:gravity="center"
                        android:text="@string/direction"
                        android:textColor="@color/welcome_text_display_color" />
                </LinearLayout>

<!--            DARK BACKGROUND FOR DIRECTION-->

            <LinearLayout
                android:id="@+id/selectDirection"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_five"
                android:layout_weight="1"
                android:paddingTop="@dimen/padding_ten"
                android:paddingBottom="@dimen/padding_ten"
                android:layout_gravity="center"
                android:background="@drawable/client_sceen_3_box"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:adjustViewBounds="true"
                    android:padding="@dimen/padding_ten"
                    android:background="@drawable/white_circular_shape_for_card"
                    android:layout_gravity="center"
                    android:src="@drawable/direction_icon" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/margin_five"
                    android:textSize="@dimen/text_twelve"
                    android:gravity="center"
                    android:text="Direction"
                    android:textColor="@color/white" />
            </LinearLayout>


        </LinearLayout>
<!-- START TASK BUTTON DESIGN CODE-->
        <LinearLayout
            android:id="@+id/startTask"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginStart="@dimen/margin_fifteen"
            android:layout_marginTop="@dimen/margin_thirty"
            android:layout_marginEnd="@dimen/margin_fifteen"
            android:background="@drawable/butoon_bg_shape"
            android:foreground="@drawable/ripple"
            android:clickable="true"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:text="@string/start_task"
                android:textColor="@color/white"
                android:textSize="@dimen/button_text_size"
                android:theme="@style/FontMedium" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>