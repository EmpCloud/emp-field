<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/swipeRefreshLayout"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.fragment.home.HomeFragment">

<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_begin="55dp"
        android:orientation="horizontal"/>

    <LinearLayout
        android:id="@+id/user_detail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="60dp"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/guideline">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/hi"
            android:textColor="@color/white"
            android:textSize="@dimen/text_twenty_four"
            android:theme="@style/FontBold" />

        <TextView
            android:id="@+id/name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:gravity="start"
            android:text=""
            android:textColor="@color/white_90"
            android:textSize="@dimen/text_twenty"
            android:theme="@style/FontBold" />

        <TextView
            android:id="@+id/role"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/white_70"
            android:textSize="@dimen/text_twelve"
            android:theme="@style/FontMedium" />
    </LinearLayout>

    <TextView
        android:id="@+id/mapCurrent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/margin_thirty"
        android:layout_marginBottom="@dimen/margin_five"
        android:clickable="true"
        android:gravity="end"
        android:paddingEnd="@dimen/_10dp_"
        android:text="@string/map"
        android:textColor="@color/white"
        app:layout_constraintBottom_toTopOf="@id/relativeLayout2"
        app:layout_constraintEnd_toEndOf="parent" />

    <RelativeLayout
        android:id="@+id/relativeLayout2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/margin_twenty"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@+id/user_detail">

        <LinearLayout
            android:id="@+id/swipeArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:layout_marginStart="@dimen/margin_twenty"
            android:layout_marginEnd="@dimen/margin_twenty"
            android:background="@drawable/edit_text_back"
            android:orientation="vertical"
            android:paddingStart="@dimen/padding_twenty"
            android:paddingEnd="@dimen/padding_twenty"
            android:paddingBottom="@dimen/padding_ten"
            android:translationZ="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/date"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_ten"
                    android:layout_weight="1"
                    android:text="Wed, Oct 04"
                    android:textColor="@color/black_text_color"
                    android:textSize="@dimen/button_text_size"
                    android:textStyle="bold"
                    android:theme="@style/FontMedium" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_ten"
                    android:layout_weight="1"
                    android:gravity="end">

                    <TextView
                        android:id="@+id/timeShow"
                        android:visibility="gone"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:background="@drawable/time_shower_shape"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:text="-- -- --"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text_fourteen"
                        android:theme="@style/FontMedium" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/margin_ten"
                android:gravity="center"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="start"
                        android:text="@string/check_in"
                        android:textColor="@color/buttonbgcolor"
                        android:textSize="@dimen/text_sixteen"
                        android:theme="@style/UbuntuRegular" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/checkinTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_medium"
                            android:gravity="start"
                            android:text="-- --"
                            android:textColor="@color/time_display_color"
                            android:textSize="@dimen/text_twenty"
                            android:theme="@style/FontMedium" />

<!--                        <TextView-->
<!--                            android:layout_width="wrap_content"-->
<!--                            android:layout_height="wrap_content"-->
<!--                            android:fontFamily="@font/montserrat_medium"-->
<!--                            android:gravity="start"-->
<!--                            android:text="am"-->
<!--                            android:textColor="@color/time_display_color"-->
<!--                            android:textSize="@dimen/text_twelve"-->
<!--                            android:theme="@style/FontMedium" />-->
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:text="@string/check_out"
                        android:textColor="@color/buttonbgcolor"
                        android:textSize="@dimen/text_sixteen"
                        android:theme="@style/UbuntuRegular" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:gravity="end"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/checkoutTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_medium"
                            android:gravity="end"
                            android:text="-- --"
                            android:textColor="@color/time_display_color"
                            android:textSize="@dimen/text_twenty"
                            android:theme="@style/FontMedium" />

<!--                        <TextView-->
<!--                            android:layout_width="wrap_content"-->
<!--                            android:layout_height="wrap_content"-->
<!--                            android:fontFamily="@font/montserrat_medium"-->
<!--                            android:gravity="start"-->
<!--                            android:text="pm"-->
<!--                            android:textColor="@color/time_display_color"-->
<!--                            android:textSize="@dimen/text_twelve"-->
<!--                            android:theme="@style/FontMedium" />-->
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_ten"
            android:layout_marginStart="@dimen/margin_thirty"
            android:layout_marginEnd="@dimen/margin_thirty">

<!--            <com.ncorti.slidetoact.SlideToActView-->
<!--                android:id="@+id/sliderActView"-->
<!--                android:layout_width="wrap_content"-->
<!--                android:layout_gravity="center"-->
<!--                android:visibility="gone"-->
<!--                android:layout_height="50dp"-->
<!--                app:inner_color="@color/swipe_innercolor"-->
<!--                app:animation_duration="200"-->
<!--                app:border_radius="120dp"-->
<!--                app:icon_margin="8dp"-->
<!--                app:slider_icon="@drawable/baseline_arrow_forward_24"-->
<!--                app:text="Swipe to Check IN"-->
<!--                app:text_color="@color/swipe_text"-->
<!--                app:outer_color="@color/swipe_outercolor"-->
<!--                android:layout_margin="10dp"-->
<!--                app:slider_locked="false"-->
<!--                app:text_size="12sp" />-->

            <com.ncorti.slidetoact.SlideToActView
                android:id="@+id/sliderActView"
                android:layout_width="match_parent"
                android:visibility="gone"
                android:layout_height="50dp"
                app:inner_color="@color/swipe_innercolor"
                app:animation_duration="250"
                app:border_radius="120dp"
                android:layout_marginStart="@dimen/margin_twenty"
                android:layout_marginEnd="@dimen/margin_twenty"
                app:icon_margin="8dp"
                app:text="Swipe to Check IN"
                app:text_color="@color/swipe_text"
                app:outer_color="@color/swipe_outercolor"
                android:layout_margin="10dp"
                app:slider_locked="false"
                app:text_size="12sp" />

            <TextView
                android:id="@+id/autoCheckInText"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:visibility="gone"
                android:gravity="center"
                android:text="Swipe to Auto Check In"
                android:textColor="@color/swipe_text"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/transport_selection_bg"
                android:layout_marginStart="@dimen/margin_twenty"
                android:layout_marginEnd="@dimen/margin_twenty"
                android:layout_margin="10dp" />

        </LinearLayout>


            <include
                android:id="@+id/swipeMultiple"
                layout="@layout/multiple_checkin_options"/>


        </LinearLayout>

        <ScrollView
            android:id="@+id/scrollview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@+id/swipeArea"
            android:scrollbars="none"
            android:translationZ="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_twenty"
                    android:layout_marginTop="@dimen/padding_twenty"
                    android:layout_marginEnd="@dimen/margin_twenty"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/yesterdaytxthome"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/yesterday_s_record"
                        android:textColor="@color/black_text_color"
                        android:textSize="@dimen/text_eighteen"
                        android:textStyle="bold"
                        android:theme="@style/FontMedium" />

                    <LinearLayout
                        android:id="@+id/yesterdaybox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_twenty"
                        android:background="@drawable/edit_text_back"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/yesterdayDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/margin_twenty"
                            android:layout_marginTop="@dimen/margin_ten"
                            android:text="-- --"
                            android:textColor="@color/bottom_icon_color"
                            android:textSize="@dimen/text_fifteen"
                            android:theme="@style/FontMedium" />

                        <LinearLayout
                            android:id="@+id/linearLayout2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_ten"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:paddingStart="@dimen/padding_ten"
                            android:paddingEnd="@dimen/padding_ten"
                            android:paddingBottom="@dimen/padding_twenty">


                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <androidx.cardview.widget.CardView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_margin="5dp"
                                    app:cardCornerRadius="15dp">

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:layout_gravity="center"
                                        android:background="@drawable/records_common_back_shape"
                                        android:gravity="center"
                                        android:orientation="vertical"
                                        android:padding="@dimen/padding_ten">

                                        <ImageView
                                            android:layout_width="50dp"
                                            android:layout_height="50dp"
                                            android:adjustViewBounds="true"
                                            android:background="@drawable/user_profile_background"
                                            android:padding="7dp"
                                            android:src="@drawable/game_icons_path_distance" />

                                        <TextView
                                            android:id="@+id/distancetxt"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_gravity="center"
                                            android:layout_marginTop="@dimen/margin_twenty"
                                            android:gravity="center"
                                            android:text="0.0 KM"
                                            android:textColor="@color/records_card_text_color"
                                            android:textSize="@dimen/text_fourteen"
                                            android:theme="@style/FontBold" />
                                    </LinearLayout>
                                </androidx.cardview.widget.CardView>

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:gravity="center"
                                    android:text="@string/distance_ntravelled"
                                    android:textColor="@color/records_card_text_color"
                                    android:textSize="@dimen/text_twelve"
                                    android:theme="@style/FontMedium" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <androidx.cardview.widget.CardView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_margin="5dp"
                                    app:cardCornerRadius="15dp">

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:layout_gravity="center"
                                        android:background="@drawable/records_common_back_shape"
                                        android:gravity="center"
                                        android:orientation="vertical"
                                        android:padding="@dimen/padding_ten">

                                        <ImageView
                                            android:layout_width="50dp"
                                            android:layout_height="50dp"
                                            android:adjustViewBounds="true"
                                            android:background="@drawable/user_profile_background"
                                            android:padding="7dp"
                                            android:src="@drawable/icon_park_outline_time" />

                                        <TextView
                                            android:id="@+id/timetxt"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_gravity="center"
                                            android:layout_marginTop="@dimen/margin_twenty"
                                            android:gravity="center"
                                            android:text="--:--:--"
                                            android:textColor="@color/records_card_text_color"
                                            android:textSize="@dimen/text_fourteen"
                                            android:theme="@style/FontBold" />
                                    </LinearLayout>
                                </androidx.cardview.widget.CardView>

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:gravity="center"
                                    android:text="@string/hrs_nworked"
                                    android:textColor="@color/records_card_text_color"
                                    android:textSize="@dimen/text_twelve"
                                    android:theme="@style/FontMedium" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <androidx.cardview.widget.CardView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_margin="5dp"
                                    app:cardCornerRadius="15dp">

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:layout_gravity="center"
                                        android:background="@drawable/records_common_back_shape"
                                        android:gravity="center"
                                        android:orientation="vertical"
                                        android:padding="@dimen/padding_ten">

                                        <ImageView
                                            android:layout_width="50dp"
                                            android:layout_height="50dp"
                                            android:adjustViewBounds="true"
                                            android:padding="7dp"
                                            android:background="@drawable/user_profile_background"
                                            android:src="@drawable/fluent_task_list_square_24_regular" />

                                        <TextView
                                            android:id="@+id/tasktxt"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_gravity="center"
                                            android:layout_marginTop="@dimen/margin_twenty"
                                            android:gravity="center"
                                            android:text="-/-"
                                            android:textColor="@color/records_card_text_color"
                                            android:textSize="@dimen/text_fourteen"
                                            android:theme="@style/FontBold" />
                                    </LinearLayout>
                                </androidx.cardview.widget.CardView>

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:gravity="center"
                                    android:text="@string/task_ncompleted"
                                    android:textColor="@color/records_card_text_color"
                                    android:textSize="@dimen/text_twelve"
                                    android:theme="@style/FontMedium" />

                            </LinearLayout>


                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_twenty"
                    android:layout_marginTop="@dimen/margin_twenty"
                    android:layout_marginEnd="@dimen/margin_twenty"
                    android:layout_marginBottom="200dp"
                    android:gravity="center"
                    android:orientation="horizontal">


                    <androidx.cardview.widget.CardView
                        android:id="@+id/attendacebtn"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_margin="5dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="15dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:background="@drawable/home_page_attendance_back_shape"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/padding_ten">

                            <ImageView
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:layout_gravity="center"
                                android:layout_marginTop="@dimen/margin_ten"
                                android:adjustViewBounds="true"
                                android:background="@drawable/user_profile_background"
                                android:padding="@dimen/padding_ten"
                                android:src="@drawable/attendance_a" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:layout_marginTop="@dimen/margin_ten"
                                android:gravity="center"
                                android:text="@string/attendance_history"
                                android:textColor="@color/white"
                                android:textSize="10sp"
                                android:theme="@style/FontBold" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/leavesbtn"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_margin="5dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="15dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:background="@drawable/home_page_leaves_shape_back"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/padding_ten">

                            <ImageView
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:layout_gravity="center"
                                android:adjustViewBounds="true"
                                android:background="@drawable/user_profile_background"
                                android:padding="@dimen/padding_ten"
                                android:src="@drawable/ll" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:layout_marginTop="@dimen/margin_ten"
                                android:gravity="center"
                                android:textSize="10sp"
                                android:text="@string/leaves"
                                android:textColor="@color/white" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/holidaysbtn"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_margin="5dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="15dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:background="@drawable/home_page_holidays_shape_back"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/padding_ten">

                            <ImageView
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:layout_gravity="center"
                                android:adjustViewBounds="true"
                                android:background="@drawable/user_profile_background"
                                android:padding="@dimen/padding_ten"
                                android:src="@drawable/hld" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:layout_marginTop="@dimen/margin_ten"
                                android:gravity="center"
                                android:text="@string/holidays"
                                android:textSize="10sp"
                                android:textColor="@color/white" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </LinearLayout>

        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="50dp"
            android:background="@drawable/profile_back_shape"
            android:orientation="vertical" />
    </RelativeLayout>

    <include layout="@layout/checkout_restrict_popup"
        android:layout_height="match_parent"
        android:layout_width="match_parent"
        android:id="@+id/checkoutpopup"/>

    <include layout="@layout/checkout_confirm_alert"
        android:layout_height="match_parent"
        android:layout_width="match_parent"
        android:id="@+id/checkout_confirm"/>

    <include layout="@layout/popup_transportselection"
        android:layout_height="match_parent"
        android:layout_width="match_parent"
        android:id="@+id/transportselection"/>

</androidx.constraintlayout.widget.ConstraintLayout>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>