# EMP Field — Environment Variables
NODE_ENV=development
PORT=6013
HOST=0.0.0.0

# Field module database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=emp_field
DB_POOL_MIN=2
DB_POOL_MAX=10

# EmpCloud master database (read-only access for user/org lookups)
EMPCLOUD_DB_HOST=localhost
EMPCLOUD_DB_PORT=3306
EMPCLOUD_DB_USER=root
EMPCLOUD_DB_PASSWORD=
EMPCLOUD_DB_NAME=empcloud

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT — HS256 secret (local fallback) + RS256 public key (EmpCloud OAuth2)
JWT_SECRET=change-this-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
# Either a PEM string with \n escapes, or a path to a .pem file. Leave blank
# to use HS256 only (dev mode).
JWT_PUBLIC_KEY=
JWT_ISSUER=empcloud

# CORS
CORS_ORIGIN=http://localhost:5180

# Internal service secret (for EmpCloud dashboard widget calls)
INTERNAL_SERVICE_SECRET=

# Shared HMAC secret for webhook events from EmpCloud core
EMPCLOUD_WEBHOOK_SECRET=
