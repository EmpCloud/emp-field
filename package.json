{
  "name": "emp-field",
  "version": "0.1.0",
  "private": true,
  "description": "Field force management module for the EmpCloud HRMS ecosystem",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/EmpCloud/emp-field.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @emp-field/server dev",
    "dev:server": "pnpm --filter @emp-field/server dev",
    "build": "pnpm -r run build",
    "build:server": "pnpm --filter @emp-field/server build",
    "test": "pnpm -r run test",
    "test:server": "pnpm --filter @emp-field/server test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "pnpm -r run lint",
    "db:migrate": "pnpm --filter @emp-field/server db:migrate",
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/dist"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
